<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | Super Admin Login</title>
    <meta name="description" content="Super Admin secure access portal.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: #080810;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* ── Background ── */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse 70% 60% at 15% 10%, rgba(220,38,38,.2) 0%, transparent 60%),
                radial-gradient(ellipse 60% 50% at 85% 90%, rgba(234,179,8,.12) 0%, transparent 60%),
                radial-gradient(ellipse 50% 40% at 50% 50%, rgba(127,29,29,.1) 0%, transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .grid-bg {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image: radial-gradient(rgba(255,255,255,.03) 1px, transparent 1px);
            background-size: 32px 32px;
        }

        /* ── Orbs ── */
        .orb {
            position: fixed; border-radius: 50%;
            filter: blur(100px); opacity: 0.12;
            animation: floatOrb 12s ease-in-out infinite;
            pointer-events: none; z-index: 0;
        }
        .orb1 { width: 500px; height: 500px; background: #dc2626; top: -200px; left: -100px; }
        .orb2 { width: 400px; height: 400px; background: #eab308; bottom: -150px; right: -80px; animation-delay: -6s; }
        @keyframes floatOrb {
            0%, 100% { transform: translate(0,0) scale(1); }
            50%       { transform: translate(25px, -35px) scale(1.05); }
        }

        /* ── Card ── */
        .login-card {
            position: relative; z-index: 1;
            background: rgba(15,10,20,.9);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(220,38,38,.2);
            border-radius: 28px;
            width: 100%; max-width: 420px;
            padding: 44px 40px;
            box-shadow: 0 32px 80px rgba(0,0,0,.7), 0 0 0 1px rgba(220,38,38,.08);
            animation: cardIn .5s cubic-bezier(.22,1,.36,1);
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(30px) scale(.97); }
            to   { opacity: 1; transform: none; }
        }

        /* Shield badge */
        .shield-wrap {
            display: flex; justify-content: center; margin-bottom: 28px;
        }
        .shield {
            width: 80px; height: 80px; border-radius: 22px;
            background: linear-gradient(135deg, #dc2626, #991b1b);
            display: flex; align-items: center; justify-content: center;
            font-size: 2.4rem;
            box-shadow: 0 12px 32px rgba(220,38,38,.45), 0 0 0 8px rgba(220,38,38,.1);
            animation: shieldPulse 3s ease-in-out infinite;
        }
        @keyframes shieldPulse {
            0%, 100% { box-shadow: 0 12px 32px rgba(220,38,38,.45), 0 0 0 8px rgba(220,38,38,.1); }
            50%       { box-shadow: 0 12px 40px rgba(220,38,38,.6),  0 0 0 14px rgba(220,38,38,.05); }
        }

        .login-title {
            text-align: center; margin-bottom: 6px;
            font-size: 1.5rem; font-weight: 900; letter-spacing: -0.5px;
            background: linear-gradient(135deg, #fef2f2, #fca5a5);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .login-sub {
            text-align: center; margin-bottom: 32px;
            font-size: 13px; color: #6b7280; line-height: 1.5;
        }
        .restricted-badge {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(220,38,38,.12); border: 1px solid rgba(220,38,38,.25);
            color: #f87171; font-size: 11px; font-weight: 700;
            padding: 4px 12px; border-radius: 100px; margin-bottom: 28px;
        }

        /* ── Form ── */
        .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
        .form-label {
            font-size: 11.5px; font-weight: 700; color: #9ca3af;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .form-input {
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(220,38,38,.18);
            border-radius: 12px; padding: 13px 16px;
            color: #f9fafb; font-size: 14px; font-family: 'Inter', sans-serif;
            transition: border-color .2s, box-shadow .2s; outline: none; width: 100%;
        }
        .form-input:focus {
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220,38,38,.15);
        }
        .form-input::placeholder { color: #374151; }

        .btn-login {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, #dc2626, #991b1b);
            color: #fff; border: none; border-radius: 13px;
            font-size: 15px; font-weight: 800; font-family: 'Inter', sans-serif;
            cursor: pointer; margin-top: 8px;
            box-shadow: 0 6px 20px rgba(220,38,38,.45);
            transition: transform .2s, box-shadow .2s;
            letter-spacing: 0.2px;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(220,38,38,.6);
        }
        .btn-login:active { transform: scale(.98); }

        /* ── Error ── */
        .error-box {
            background: rgba(220,38,38,.12);
            border: 1px solid rgba(220,38,38,.3);
            color: #fca5a5; font-size: 13px; font-weight: 600;
            border-radius: 12px; padding: 12px 16px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 8px;
        }

        /* ── Security notice ── */
        .security-note {
            margin-top: 24px; text-align: center;
            font-size: 11.5px; color: #374151; line-height: 1.6;
        }
        .security-note a { color: #6b7280; text-decoration: none; }
        .security-note a:hover { color: #9ca3af; }
    </style>
</head>
<body>

    <div class="grid-bg"></div>
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <div class="login-card">

        <div class="shield-wrap">
            <div class="shield">🛡️</div>
        </div>

        <div style="text-align:center; margin-bottom: 4px;">
            <span class="restricted-badge">🔒 RESTRICTED ACCESS</span>
        </div>

        <div class="login-title">Super Admin Portal</div>
        <div class="login-sub">Authorized personnel only. All access attempts are logged.</div>

        <% if (error) { %>
        <div class="error-box">⚠️ <%= error %></div>
        <% } %>

        <form action="/superadmin/admin/login" method="POST" autocomplete="off">
            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input
                    type="email"
                    name="email"
                    class="form-input"
                    placeholder="superadmin@domain.com"
                    required
                    autocomplete="off"
                >
            </div>
            <div class="form-group">
                <label class="form-label">Master Password</label>
                <input
                    type="password"
                    name="password"
                    class="form-input"
                    placeholder="••••••••••"
                    required
                    autocomplete="new-password"
                >
            </div>
            <button type="submit" class="btn-login">🛡️ Access Super Admin Panel</button>
        </form>

        <div class="security-note">
            This portal is restricted to authorized administrators only.<br>
            <a href="/">← Return to public store</a>
        </div>
    </div>

</body>
</html>
