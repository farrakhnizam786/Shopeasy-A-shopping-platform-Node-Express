<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | Admin Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f0f1a;
            --sidebar: #13132a;
            --surface: #1a1a2e;
            --surface2: #1e1e3a;
            --border: rgba(255,255,255,0.07);
            --primary: #7c3aed;
            --primary-light: #a78bfa;
            --primary-dark: #5b21b6;
            --accent: #0ea5e9;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --text-faint: #475569;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            width: 240px;
            flex-shrink: 0;
            background: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 24px 20px 20px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 10px;
        }
        .sidebar-logo {
            width: 36px; height: 36px; border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), #0ea5e9);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
            box-shadow: 0 4px 14px rgba(124,58,237,.4);
        }
        .sidebar-title {
            font-size: 1rem; font-weight: 800; letter-spacing: -0.3px;
            background: linear-gradient(135deg, var(--primary-light), #60a5fa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .sidebar-sub { font-size: 10px; color: var(--text-faint); margin-top: 1px; font-weight: 600; letter-spacing: 0.5px; }

        .sidebar-section-label {
            font-size: 10px; font-weight: 700; color: var(--text-faint);
            text-transform: uppercase; letter-spacing: 0.8px;
            padding: 20px 20px 8px;
        }

        .sidebar-nav { display: flex; flex-direction: column; gap: 3px; padding: 0 10px; }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px; border-radius: 10px;
            color: var(--text-muted); font-size: 13.5px; font-weight: 600;
            text-decoration: none; cursor: pointer;
            transition: all .2s;
        }
        .nav-item:hover { background: var(--surface2); color: var(--text); }
        .nav-item.active { background: rgba(124,58,237,.15); color: var(--primary-light); }
        .nav-item .nav-icon { font-size: 1rem; flex-shrink: 0; }

        .sidebar-footer {
            margin-top: auto; padding: 16px 10px;
            border-top: 1px solid var(--border);
            display: flex; flex-direction: column; gap: 4px;
        }
        .sidebar-footer a { color: var(--danger); }
        .sidebar-footer a:hover { background: rgba(239,68,68,.1); color: #f87171; }

        /* ─── MAIN CONTENT ─── */
        .main {
            flex: 1;
            display: flex; flex-direction: column;
            overflow: hidden;
            background: var(--bg);
            position: relative;
        }
        .main::before {
            content: '';
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse 60% 40% at 80% 0%, rgba(124,58,237,.1) 0%, transparent 55%),
                radial-gradient(ellipse 40% 30% at 0% 100%, rgba(14,165,233,.08) 0%, transparent 55%);
            pointer-events: none; z-index: 0;
        }

        /* ─── TOPBAR ─── */
        .topbar {
            position: sticky; top: 0; z-index: 100;
            padding: 0 32px;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(15,15,26,.8); backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }
        .topbar-left h1 { font-size: 1.15rem; font-weight: 800; }
        .topbar-left p { font-size: 12px; color: var(--text-faint); margin-top: 1px; }
        .topbar-right { display: flex; align-items: center; gap: 10px; }
        .top-badge {
            display: flex; align-items: center; gap: 7px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 7px 14px;
            font-size: 13px; font-weight: 600; color: var(--text-muted);
        }
        .top-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); flex-shrink: 0; animation: pulse 2s infinite; }
        @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:.4; } }

        /* ─── CONTENT AREA ─── */
        .content { padding: 28px 32px; overflow-y: auto; flex: 1; position: relative; z-index: 1; }

        /* ─── STAT CARDS ─── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 16px; margin-bottom: 28px;
        }
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px; padding: 20px;
            display: flex; flex-direction: column; gap: 10px;
            position: relative; overflow: hidden;
            transition: transform .25s, border-color .25s;
        }
        .stat-card:hover { transform: translateY(-4px); border-color: rgba(124,58,237,.25); }
        .stat-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
            background: var(--stat-color, var(--primary));
            border-radius: 18px 18px 0 0;
        }
        .stat-icon {
            font-size: 1.4rem; width: 42px; height: 42px;
            background: rgba(255,255,255,.05); border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
        }
        .stat-num { font-size: 1.9rem; font-weight: 900; line-height: 1; }
        .stat-label { font-size: 12px; color: var(--text-faint); font-weight: 600; }

        /* ─── SECTION HEADER ─── */
        .section-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 18px;
        }
        .section-header h2 { font-size: 1rem; font-weight: 800; }
        .section-header p { font-size: 12px; color: var(--text-faint); margin-top: 2px; }

        /* ─── PANEL ─── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px; overflow: hidden;
            margin-bottom: 28px;
        }
        .panel-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 10px;
        }
        .panel-header h3 { font-size: .95rem; font-weight: 800; }
        .panel-icon { font-size: 1.1rem; }
        .panel-body { padding: 20px; }

        /* ─── ADD PRODUCT FORM ─── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }
        .form-grid .full { grid-column: 1 / -1; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-label { font-size: 11.5px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }

        input[type="text"],
        input[type="number"],
        textarea,
        select {
            background: rgba(255,255,255,.04);
            border: 1px solid var(--border);
            border-radius: 11px; padding: 11px 14px;
            color: var(--text); font-size: 14px; font-family: 'Inter', sans-serif;
            transition: border-color .2s, box-shadow .2s; outline: none; width: 100%;
        }
        input:focus, textarea:focus, select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(124,58,237,.15);
        }
        input::placeholder, textarea::placeholder { color: var(--text-faint); }
        textarea { resize: vertical; min-height: 80px; }
        select option { background: #1a1a2e; color: var(--text); }

        /* Category badge in table */
        .cat-badge {
            display: inline-flex; align-items: center;
            background: rgba(124,58,237,.12); border: 1px solid rgba(124,58,237,.25);
            color: var(--primary-light); font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 100px; white-space: nowrap;
        }

        .btn-add {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff; border: none; border-radius: 11px;
            padding: 12px 24px; font-size: 14px; font-weight: 700;
            font-family: 'Inter', sans-serif; cursor: pointer;
            box-shadow: 0 4px 14px rgba(124,58,237,.4);
            transition: transform .2s, box-shadow .2s;
            display: inline-flex; align-items: center; gap: 7px;
        }
        .btn-add:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(124,58,237,.55); }
        .btn-add:active { transform: scale(.97); }

        /* ─── PRODUCTS TABLE ─── */
        .table-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 560px; }
        thead tr { border-bottom: 1px solid var(--border); }
        th {
            padding: 11px 14px; text-align: left;
            font-size: 11px; font-weight: 700; color: var(--text-faint);
            text-transform: uppercase; letter-spacing: 0.6px; white-space: nowrap;
        }
        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .18s;
        }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: rgba(255,255,255,.025); }
        td { padding: 13px 14px; font-size: 13.5px; color: var(--text-muted); vertical-align: middle; }
        td:first-child { color: var(--text); font-weight: 600; }
        .td-price { color: var(--primary-light); font-weight: 800; font-size: 14px; }
        .td-img {
            width: 42px; height: 42px; border-radius: 10px; object-fit: cover;
            background: var(--surface2); border: 1px solid var(--border);
            vertical-align: middle;
        }
        .td-desc { max-width: 240px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .empty-state {
            text-align: center; padding: 40px 20px;
            color: var(--text-faint); font-size: 14px;
        }
        .empty-state span { display: block; font-size: 2.5rem; margin-bottom: 10px; opacity: .4; }

        /* Product count badge */
        .count-badge {
            background: rgba(124,58,237,.18); color: var(--primary-light);
            font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 100px;
            margin-left: 8px;
        }

        /* Action buttons */
        .action-btns { display: flex; gap: 8px; align-items: center; }
        .btn-edit {
            background: rgba(14,165,233,.15); border: 1px solid rgba(14,165,233,.3);
            color: #38bdf8; font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif;
            padding: 6px 14px; border-radius: 8px; cursor: pointer;
            transition: all .2s; display: inline-flex; align-items: center; gap: 5px;
        }
        .btn-edit:hover { background: rgba(14,165,233,.28); border-color: #0ea5e9; transform: translateY(-1px); }
        .btn-del {
            background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.25);
            color: #f87171; font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif;
            padding: 6px 14px; border-radius: 8px; cursor: pointer;
            transition: all .2s; display: inline-flex; align-items: center; gap: 5px;
        }
        .btn-del:hover { background: rgba(239,68,68,.25); border-color: #ef4444; transform: translateY(-1px); }

        /* Edit Modal */
        .modal-overlay {
            position: fixed; inset: 0; z-index: 500;
            background: rgba(0,0,0,.7); backdrop-filter: blur(6px);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity .3s;
            padding: 20px;
        }
        .modal-overlay.open { opacity: 1; pointer-events: all; }
        .modal-box {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 22px; width: 100%; max-width: 500px;
            box-shadow: 0 32px 64px rgba(0,0,0,.6);
            animation: modalPop .3s cubic-bezier(.22,1,.36,1);
            overflow: hidden;
        }
        @keyframes modalPop { from { opacity:0; transform:scale(.92) translateY(20px); } to { opacity:1; transform:none; } }
        .modal-head {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .modal-head h3 { font-size: 1rem; font-weight: 800; }
        .modal-close {
            width: 32px; height: 32px; border-radius: 9px;
            background: var(--surface2); border: 1px solid var(--border);
            color: var(--text-muted); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; transition: .2s;
        }
        .modal-close:hover { background: rgba(239,68,68,.15); color: var(--danger); border-color: var(--danger); }
        .modal-body { padding: 22px; display: flex; flex-direction: column; gap: 14px; }
        .btn-save {
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            color: #fff; border: none; border-radius: 11px;
            padding: 13px; font-size: 14px; font-weight: 800;
            font-family: 'Inter', sans-serif; cursor: pointer; width: 100%;
            box-shadow: 0 4px 14px rgba(14,165,233,.4);
            transition: transform .2s, box-shadow .2s; margin-top: 4px;
        }
        .btn-save:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(14,165,233,.55); }

        /* ─── ORDER TABLE ─── */
        .order-status-form { display: flex; gap: 6px; align-items: center; }
        .status-select {
            background: rgba(255,255,255,.05); border: 1px solid var(--border); border-radius: 8px;
            padding: 6px 10px; color: var(--text); font-size: 12.5px; font-family: 'Inter', sans-serif;
            outline: none; cursor: pointer;
        }
        .btn-update-status {
            background: rgba(16,185,129,.15); border: 1px solid rgba(16,185,129,.3);
            color: #34d399; font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif;
            padding: 6px 12px; border-radius: 8px; cursor: pointer; transition: .2s;
        }
        .btn-update-status:hover { background: rgba(16,185,129,.28); border-color: #10b981; }
        .btn-view-inv {
            background: rgba(124,58,237,.12); border: 1px solid rgba(124,58,237,.25);
            color: var(--primary-light); font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif;
            padding: 6px 12px; border-radius: 8px; cursor: pointer; text-decoration: none;
            transition: .2s; display: inline-flex; align-items: center; gap: 4px;
        }
        .btn-view-inv:hover { background: rgba(124,58,237,.25); }
        .order-status-badge {
            display: inline-flex; align-items: center;
            font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 100px;
        }
        .os-pending   { background: rgba(245,158,11,.15); border: 1px solid rgba(245,158,11,.3); color: #fbbf24; }
        .os-process   { background: rgba(59,130,246,.15); border: 1px solid rgba(59,130,246,.3); color: #60a5fa; }
        .os-delivery  { background: rgba(139,92,246,.15); border: 1px solid rgba(139,92,246,.3); color: #c084fc; }
        .os-delivered { background: rgba(16,185,129,.15); border: 1px solid rgba(16,185,129,.3); color: #34d399; }
        .os-cancelled { background: rgba(239,68,68,.15);  border: 1px solid rgba(239,68,68,.3);  color: #f87171; }
        /* ─── COMPLAINTS ─── */
        .complaint-strip {
            background: rgba(255,255,255,.02); border: 1px solid var(--border);
            border-radius: 14px; padding: 14px 18px; margin-bottom: 10px;
        }
        .complaint-strip:last-child { margin-bottom: 0; }
        .complaint-top { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
        .complaint-subject { font-size: 14px; font-weight: 700; color: var(--text); }
        .complaint-meta { font-size: 12px; color: var(--text-faint); }
        .complaint-msg { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 10px; }
        .complaint-reply { background: rgba(124,58,237,.08); border: 1px solid rgba(124,58,237,.18); border-radius: 10px; padding: 10px 14px; font-size: 13px; color: var(--primary-light); margin-bottom: 8px; }
        .btn-reply {
            background: rgba(14,165,233,.15); border: 1px solid rgba(14,165,233,.3);
            color: #38bdf8; font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif;
            padding: 6px 14px; border-radius: 8px; cursor: pointer; transition: .2s;
        }
        .btn-reply:hover { background: rgba(14,165,233,.28); }
        /* ─── REPLY MODAL ─── */
        .reply-modal-overlay {
            position: fixed; inset: 0; z-index: 600;
            background: rgba(0,0,0,.75); backdrop-filter: blur(6px);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity .3s; padding: 20px;
        }
        .reply-modal-overlay.open { opacity: 1; pointer-events: all; }
        .reply-modal-box {
            background: var(--surface); border: 1px solid var(--border); border-radius: 22px;
            width: 100%; max-width: 480px; overflow: hidden;
            animation: modalPop .3s cubic-bezier(.22,1,.36,1);
        }
        .reply-modal-head { padding: 16px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
        .reply-modal-head h3 { font-size: .95rem; font-weight: 800; }
        .reply-modal-body { padding: 22px; display: flex; flex-direction: column; gap: 14px; }
        .reply-modal-body select, .reply-modal-body textarea {
            background: rgba(255,255,255,.05); border: 1px solid var(--border); border-radius: 10px;
            padding: 11px 14px; color: var(--text); font-size: 14px; font-family: 'Inter', sans-serif;
            outline: none; width: 100%; transition: border-color .2s;
        }
        .reply-modal-body select:focus, .reply-modal-body textarea:focus { border-color: var(--accent); }
        .reply-modal-body textarea { resize: vertical; min-height: 90px; }
        .btn-send-reply {
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            color: #fff; border: none; border-radius: 11px;
            padding: 13px; font-size: 14px; font-weight: 800; font-family: 'Inter', sans-serif;
            cursor: pointer; width: 100%; box-shadow: 0 4px 14px rgba(14,165,233,.35);
            transition: transform .2s, box-shadow .2s;
        }
        .btn-send-reply:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(14,165,233,.5); }

        /* ─── SCROLLBAR ─── */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    </style>
</head>
<body>

<!-- ════════════ SIDEBAR ════════════ -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-logo">⚡</div>
        <div>
            <div class="sidebar-title">ShopEasy</div>
            <div class="sidebar-sub">ADMIN PANEL</div>
        </div>
    </div>

    <div class="sidebar-section-label">Main</div>
    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item active">
            <span class="nav-icon">📦</span> Inventory
        </a>
        <a href="#orders" class="nav-item" onclick="scrollTo('orders')">
            <span class="nav-icon">🛒</span> Orders
        </a>
        <a href="#complaints" class="nav-item" onclick="scrollTo('complaints')">
            <span class="nav-icon">🚨</span> Complaints
        </a>
        <a href="/" class="nav-item">
            <span class="nav-icon">🛍️</span> View Shop
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="/logout" class="nav-item">
            <span class="nav-icon">🚪</span> Logout
        </a>
    </div>
</aside>

<!-- ════════════ MAIN ════════════ -->
<div class="main">

    <!-- Topbar -->
    <div class="topbar">
        <div class="topbar-left">
            <h1>Inventory Management</h1>
            <p>Manage all your products from one place</p>
        </div>
        <div class="topbar-right">
            <div class="top-badge">
                <span class="dot"></span>
                <span><%= products.length %> Products</span>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="content">

        <!-- Stat Cards -->
        <div class="stats-row">
            <div class="stat-card" style="--stat-color:#7c3aed">
                <div class="stat-icon">📦</div>
                <div class="stat-num"><%= products.length %></div>
                <div class="stat-label">Total Products</div>
            </div>
            <div class="stat-card" style="--stat-color:#0ea5e9">
                <div class="stat-icon">💰</div>
                <div class="stat-num">
                    <%
                        var total = 0;
                        products.forEach(function(p){ total += Number(p.price) || 0; });
                    %>
                    ₹<%= total.toLocaleString('en-IN') %>
                </div>
                <div class="stat-label">Total Catalogue Value</div>
            </div>
            <div class="stat-card" style="--stat-color:#10b981">
                <div class="stat-icon">🛒</div>
                <div class="stat-num"><%= typeof todayOrders !== 'undefined' ? todayOrders : 0 %></div>
                <div class="stat-label">Today's Orders</div>
            </div>
            <div class="stat-card" style="--stat-color:#f59e0b">
                <div class="stat-icon">💵</div>
                <div class="stat-num">₹<%= typeof todayIncome !== 'undefined' ? Number(todayIncome).toLocaleString('en-IN') : 0 %></div>
                <div class="stat-label">Today's Income</div>
            </div>
        </div>

        <!-- Add Product Form -->
        <div class="panel">
            <div class="panel-header">
                <span class="panel-icon">➕</span>
                <h3>Add New Product</h3>
            </div>
            <div class="panel-body">
                <form action="/add-product" method="POST">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Product Name</label>
                            <input type="text" name="name" placeholder="e.g. Wireless Headphones" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Price (₹)</label>
                            <input type="number" name="price" placeholder="e.g. 1499" min="0" required>
                        </div>
                        <div class="form-group full">
                            <label class="form-label">Image URL <span style="color:var(--text-faint);text-transform:none;">(optional)</span></label>
                            <input type="text" name="image" placeholder="https://example.com/image.jpg">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <select name="category">
                                <option value="Uncategorized">Uncategorized</option>
                                <option value="Electronics">Electronics</option>
                                <option value="Fashion">Fashion</option>
                                <option value="Home &amp; Living">Home &amp; Living</option>
                                <option value="Sports">Sports</option>
                                <option value="Beauty">Beauty</option>
                                <option value="Books">Books</option>
                                <option value="Food &amp; Drinks">Food &amp; Drinks</option>
                                <option value="Toys">Toys</option>
                            </select>
                        </div>
                        <div class="form-group full">
                            <label class="form-label">Description</label>
                            <textarea name="description" placeholder="Brief product description…"></textarea>
                        </div>
                    </div>
                    <div style="margin-top:18px;">
                        <button type="submit" class="btn-add">
                            ➕ Add Product
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Products Table -->
        <div class="panel">
            <div class="panel-header">
                <span class="panel-icon">📋</span>
                <h3>
                    Current Products
                    <span class="count-badge"><%= products.length %></span>
                </h3>
            </div>
            <div class="table-wrap">
                <% if (products.length === 0) { %>
                <div class="empty-state">
                    <span>📦</span>
                    No products yet. Add your first product above!
                </div>
                <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(function(p) { %>
                        <tr>
                            <td>
                                <img
                                    class="td-img"
                                    src="<%= p.image || '' %>"
                                    alt="<%= p.name %>"
                                    onerror="this.src='https://placehold.co/42x42/1a1a2e/7c3aed?text=P'"
                                >
                            </td>
                            <td><%= p.name %></td>
                            <td><span class="cat-badge"><%= p.category || 'Uncategorized' %></span></td>
                            <td class="td-price">₹<%= Number(p.price).toLocaleString('en-IN') %></td>
                            <td class="td-desc"><%= p.description || '—' %></td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn-edit"
                                        data-id="<%= p._id %>"
                                        data-name="<%= p.name %>"
                                        data-price="<%= p.price %>"
                                        data-image="<%= p.image || '' %>"
                                        data-desc="<%= p.description || '' %>"
                                        data-category="<%= p.category || 'Uncategorized' %>"
                                        onclick="openEdit(this)">
                                        ✏️ Edit
                                    </button>
                                    <form action="/delete-product/<%= p._id %>" method="POST" style="margin:0"
                                          onsubmit="return confirm('Delete this product? This cannot be undone.')">
                                        <button type="submit" class="btn-del">🗑️ Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <% } %>
            </div>
        </div>

        <%
            var pmI = {upi:'📱',card:'💳',wallet:'👛',cod:'💵'};
            var scMap = {'Pending':'os-pending','In Process':'os-process','Out for Delivery':'os-delivery','Delivered':'os-delivered','Cancelled':'os-cancelled'};
        %>

        <!-- ─── ORDERS PANEL ─── -->
        <div class="panel" id="orders">
            <div class="panel-header">
                <span class="panel-icon">🛒</span>
                <h3>Recent Orders <span class="count-badge"><%= typeof allOrders !== 'undefined' ? allOrders.length : 0 %></span></h3>
            </div>
            <div class="table-wrap">
                <% if (!allOrders || allOrders.length === 0) { %>
                <div class="empty-state"><span>🛒</span>No orders yet.</div>
                <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% allOrders.forEach(function(ord){ %>
                    <tr>
                        <td style="font-size:12px;color:var(--primary-light);font-weight:700">#<%= ord.orderId %></td>
                        <td><%= ord.customerEmail %></td>
                        <td style="font-size:12px"><%= ord.items.length %> item<%= ord.items.length>1?'s':'' %></td>
                        <td class="td-price">₹<%= Number(ord.total).toLocaleString('en-IN') %></td>
                        <td style="font-size:13px"><%= pmI[ord.payment] || '' %> <%= ord.payment %></td>
                        <td><span class="order-status-badge <%= scMap[ord.status]||'os-pending' %>"><%= ord.status %></span></td>
                        <td style="font-size:12px"><%= new Date(ord.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                        <td>
                            <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
                                <form action="/admin/orders/<%= ord._id %>/status" method="POST" class="order-status-form">
                                    <select name="status" class="status-select">
                                        <% ['Pending','In Process','Out for Delivery','Delivered','Cancelled'].forEach(function(s){ %>
                                        <option value="<%= s %>" <%= ord.status===s?'selected':'' %>><%= s %></option>
                                        <% }); %>
                                    </select>
                                    <button type="submit" class="btn-update-status">✓ Save</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                    </tbody>
                </table>
                <% } %>
            </div>
        </div>

        <!-- ─── COMPLAINTS PANEL ─── -->
        <div class="panel" id="complaints">
            <div class="panel-header">
                <span class="panel-icon">🚨</span>
                <h3>Customer Complaints <span class="count-badge"><%= typeof complaints !== 'undefined' ? complaints.length : 0 %></span></h3>
            </div>
            <div class="panel-body">
                <% if (!complaints || complaints.length === 0) { %>
                <div class="empty-state"><span>✅</span>No complaints yet!</div>
                <% } else { %>
                <% complaints.forEach(function(c){ %>
                <div class="complaint-strip">
                    <div class="complaint-top">
                        <div>
                            <div class="complaint-subject"><%= c.subject %></div>
                            <div class="complaint-meta">Order #<%= c.orderId %> · <%= c.customerEmail %> · <%= new Date(c.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                        </div>
                        <span class="order-status-badge <%= c.status==='Resolved'?'os-delivered':c.status==='In Review'?'os-process':'os-pending' %>"><%= c.status %></span>
                    </div>
                    <div class="complaint-msg"><%= c.message %></div>
                    <% if (c.adminReply) { %>
                    <div class="complaint-reply">📨 <strong>Your reply:</strong> <%= c.adminReply %></div>
                    <% } %>
                    <button class="btn-reply" onclick="openReply('<%= c._id %>','<%= c.status %>')">💬 Reply / Update Status</button>
                </div>
                <% }); %>
                <% } %>
            </div>
        </div>

    </div><!-- /content -->
</div><!-- /main -->

<!-- ════ EDIT MODAL ════ -->
<div class="modal-overlay" id="edit-modal" onclick="closeEditOnBg(event)">
    <div class="modal-box">
        <div class="modal-head">
            <h3>✏️ Edit Product</h3>
            <button class="modal-close" onclick="closeEdit()">✕</button>
        </div>
        <div class="modal-body">
            <form id="edit-form" method="POST">
                <div class="form-group">
                    <label class="form-label">Product Name</label>
                    <input type="text" id="edit-name" name="name" placeholder="Product name" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Price (₹)</label>
                    <input type="number" id="edit-price" name="price" placeholder="e.g. 1499" min="0" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select id="edit-category" name="category">
                        <option value="Uncategorized">Uncategorized</option>
                        <option value="Electronics">Electronics</option>
                        <option value="Fashion">Fashion</option>
                        <option value="Home &amp; Living">Home &amp; Living</option>
                        <option value="Sports">Sports</option>
                        <option value="Beauty">Beauty</option>
                        <option value="Books">Books</option>
                        <option value="Food &amp; Drinks">Food &amp; Drinks</option>
                        <option value="Toys">Toys</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Image URL</label>
                    <input type="text" id="edit-image" name="image" placeholder="https://…">
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea id="edit-desc" name="description" rows="3" placeholder="Brief description…"></textarea>
                </div>
                <button type="submit" class="btn-save">💾 Save Changes</button>
            </form>
        </div>
    </div>
</div>

<!-- ════ REPLY MODAL ════ -->
<div class="reply-modal-overlay" id="reply-modal" onclick="closeReplyOnBg(event)">
    <div class="reply-modal-box">
        <div class="reply-modal-head">
            <h3>💬 Reply to Complaint</h3>
            <button class="modal-close" onclick="closeReply()">✕</button>
        </div>
        <form id="reply-form" method="POST" class="reply-modal-body">
            <div>
                <label class="form-label">Update Status</label>
                <select name="status" id="reply-status">
                    <option value="Open">Open</option>
                    <option value="In Review">In Review</option>
                    <option value="Resolved">Resolved</option>
                </select>
            </div>
            <div>
                <label class="form-label">Your Reply</label>
                <textarea name="reply" placeholder="Type your reply to the customer…" required></textarea>
            </div>
            <button type="submit" class="btn-send-reply">📨 Send Reply</button>
        </form>
    </div>
</div>

<script>
    function openReply(cId, currentStatus) {
        document.getElementById('reply-form').action = '/admin/complaints/' + cId + '/reply';
        document.getElementById('reply-status').value = currentStatus || 'Open';
        document.getElementById('reply-modal').classList.add('open');
    }
    function closeReply() { document.getElementById('reply-modal').classList.remove('open'); }
    function closeReplyOnBg(e) { if (e.target === document.getElementById('reply-modal')) closeReply(); }

    function scrollTo(id) {
        var el = document.getElementById(id);
        if (el) { setTimeout(function(){ el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100); }
    }

    function openEdit(btn) {
        var id       = btn.getAttribute('data-id');
        var name     = btn.getAttribute('data-name');
        var price    = btn.getAttribute('data-price');
        var image    = btn.getAttribute('data-image');
        var desc     = btn.getAttribute('data-desc');
        var category = btn.getAttribute('data-category') || 'Uncategorized';

        document.getElementById('edit-form').action      = '/edit-product/' + id;
        document.getElementById('edit-name').value       = name;
        document.getElementById('edit-price').value      = price;
        document.getElementById('edit-image').value      = image;
        document.getElementById('edit-desc').value       = desc;
        document.getElementById('edit-category').value   = category;
        document.getElementById('edit-modal').classList.add('open');
    }
    function closeEdit() {
        document.getElementById('edit-modal').classList.remove('open');
    }
    function closeEditOnBg(e) {
        if (e.target === document.getElementById('edit-modal')) closeEdit();
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeEdit();
    });
</script>

</body>
</html>