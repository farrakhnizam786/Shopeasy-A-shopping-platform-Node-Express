<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | My Account</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary:#ff6b35; --primary-dark:#e55a25; --primary-light:#ff8c5c; --primary-pale:#fff3ef;
            --success:#22c55e; --danger:#ef4444; --warning:#f59e0b;
            --bg:#f8f9fa; --white:#fff; --border:#e5e7eb;
            --text:#111827; --text-muted:#6b7280; --text-faint:#9ca3af;
            --shadow:0 2px 12px rgba(0,0,0,0.07); --shadow-lg:0 8px 32px rgba(0,0,0,0.1);
        }
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
        nav{position:sticky;top:0;z-index:100;height:64px;padding:0 5%;display:flex;align-items:center;justify-content:space-between;background:#fff;border-bottom:1px solid var(--border);box-shadow:var(--shadow)}
        .nav-logo{font-size:1.25rem;font-weight:900;color:var(--primary);display:flex;align-items:center;gap:6px;text-decoration:none}
        .nav-logo span{color:var(--text)}
        .nav-actions{display:flex;align-items:center;gap:10px}
        .nav-btn{padding:8px 18px;border-radius:10px;font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;text-decoration:none;transition:.2s;border:1.5px solid var(--border)}
        .btn-outline{background:transparent;color:var(--text-muted)}.btn-outline:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-pale)}
        .btn-danger{background:transparent;border-color:rgba(239,68,68,.3);color:#ef4444}.btn-danger:hover{background:rgba(239,68,68,.07);border-color:var(--danger)}
        .page{max-width:940px;margin:0 auto;padding:32px 5% 80px}
        .alert{padding:12px 18px;border-radius:12px;font-size:13px;font-weight:600;margin-bottom:20px;display:flex;align-items:center;gap:8px}
        .alert-success{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#15803d}
        .profile-hero{background:#fff;border:1px solid var(--border);border-radius:22px;overflow:hidden;margin-bottom:20px;box-shadow:var(--shadow)}
        .profile-banner{height:100px;background:linear-gradient(135deg,var(--primary) 0%,#ff8c5c 50%,#ffd700 100%)}
        .profile-main{padding:0 26px 26px;display:flex;align-items:flex-end;gap:20px;margin-top:-44px;flex-wrap:wrap}
        .avatar{width:84px;height:84px;border-radius:22px;background:linear-gradient(135deg,var(--primary),var(--primary-light));border:4px solid #fff;display:flex;align-items:center;justify-content:center;font-size:2.1rem;font-weight:900;color:#fff;box-shadow:0 8px 20px rgba(255,107,53,.3)}
        .avatar-status{position:absolute;bottom:4px;right:-3px;width:15px;height:15px;border-radius:50%;background:var(--success);border:3px solid #fff}
        .avatar-wrap{position:relative;flex-shrink:0}
        .profile-info{flex:1;min-width:180px;padding-top:48px}
        .profile-name{font-size:1.25rem;font-weight:900}
        .profile-email{font-size:13px;color:var(--text-muted);margin-top:3px}
        .profile-role{display:inline-flex;align-items:center;gap:5px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#15803d;font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;margin-top:8px}
        .stats-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:14px;margin-bottom:20px}
        .stat-card{background:#fff;border:1px solid var(--border);border-radius:17px;padding:18px;display:flex;flex-direction:column;gap:7px;position:relative;overflow:hidden;transition:transform .25s,box-shadow .25s;box-shadow:var(--shadow)}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--stat-clr,var(--primary));border-radius:17px 17px 0 0}
        .stat-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg)}
        .stat-em{font-size:1.2rem}.stat-num{font-size:1.6rem;font-weight:900;line-height:1}.stat-lbl{font-size:11px;color:var(--text-faint);font-weight:600}
        .panel{background:#fff;border:1px solid var(--border);border-radius:20px;overflow:hidden;margin-bottom:18px;box-shadow:var(--shadow)}
        .panel-head{padding:15px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:linear-gradient(135deg,var(--primary-pale),#fff)}
        .panel-head h3{font-size:.95rem;font-weight:800}
        .panel-body{padding:20px 22px}
        /* ORDERS TABLE */
        .order-row{background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:16px 18px;margin-bottom:12px}
        .order-row:last-child{margin-bottom:0}
        .order-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:10px}
        .order-id-lbl{font-size:14px;font-weight:800}
        .order-date{font-size:12px;color:var(--text-faint)}
        .order-badges{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
        .badge{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:700;padding:4px 12px;border-radius:100px}
        .badge-orange{background:var(--primary-pale);border:1px solid rgba(255,107,53,.2);color:var(--primary)}
        .badge-green{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#15803d}
        .badge-blue{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);color:#1d4ed8}
        .badge-purple{background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.2);color:#6d28d9}
        .badge-gray{background:rgba(107,114,128,.1);border:1px solid rgba(107,114,128,.2);color:#374151}
        .badge-red{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:#b91c1c}
        .order-items-list{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
        .order-item-chip{font-size:12px;color:var(--text-muted);background:#fff;border:1px solid var(--border);padding:3px 10px;border-radius:8px}
        .order-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
        .order-total{font-size:1.1rem;font-weight:900;color:var(--primary)}
        .order-actions{display:flex;gap:8px;flex-wrap:wrap}
        .action-btn{padding:7px 14px;border-radius:9px;font-size:12.5px;font-weight:700;font-family:inherit;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:5px;border:1.5px solid var(--border);background:#fff;color:var(--text);transition:.2s}
        .action-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-pale)}
        .action-btn.danger{border-color:rgba(239,68,68,.2);color:#b91c1c}.action-btn.danger:hover{background:rgba(239,68,68,.08);border-color:var(--danger)}
        /* ACCOUNT */
        .detail-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--border)}
        .detail-row:last-child{border-bottom:none}
        .detail-label{font-size:12px;color:var(--text-faint);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
        .detail-value{font-size:14px;font-weight:600}
        /* ACTIONS GRID */
        .actions-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
        .action-tile{background:var(--bg);border:1.5px solid var(--border);border-radius:14px;padding:16px;text-decoration:none;color:var(--text-muted);display:flex;align-items:center;gap:12px;transition:.22s;cursor:pointer}
        .action-tile:hover{border-color:var(--primary);color:var(--text);transform:translateY(-2px);background:var(--primary-pale);box-shadow:var(--shadow)}
        .tile-icon{width:42px;height:42px;border-radius:12px;background:#fff;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0}
        .tile-text{font-size:13.5px;font-weight:700}.tile-sub{font-size:11.5px;color:var(--text-faint);margin-top:2px}
        /* MODAL */
        .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:.3s;padding:20px}
        .modal-overlay.open{opacity:1;pointer-events:all}
        .modal-box{background:#fff;border:1px solid var(--border);border-radius:22px;width:100%;max-width:480px;overflow:hidden;animation:mPop .3s cubic-bezier(.22,1,.36,1)}
        @keyframes mPop{from{opacity:0;transform:scale(.92)translateY(16px)}to{opacity:1;transform:none}}
        .modal-head{padding:16px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:linear-gradient(135deg,var(--primary-pale),#fff)}
        .modal-head h3{font-size:.95rem;font-weight:800}
        .modal-close{width:32px;height:32px;border-radius:9px;background:var(--bg);border:1px solid var(--border);color:var(--text-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;transition:.2s}
        .modal-close:hover{background:rgba(239,68,68,.1);color:var(--danger);border-color:var(--danger)}
        .modal-body{padding:22px;display:flex;flex-direction:column;gap:14px}
        .fg{display:flex;flex-direction:column;gap:6px}
        .fg label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px}
        .fg input,.fg select,.fg textarea{padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:inherit;outline:none;transition:.2s;background:var(--bg)}
        .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--primary);background:#fff;box-shadow:0 0 0 3px rgba(255,107,53,.1)}
        .fg textarea{resize:vertical;min-height:80px}
        .btn-submit{width:100%;padding:13px;background:var(--primary);color:#fff;border:none;border-radius:12px;font-size:.9rem;font-weight:800;font-family:inherit;cursor:pointer;transition:.2s}
        .btn-submit:hover{background:var(--primary-dark);transform:translateY(-1px)}
        /* COMPLAINTS */
        .complaint-row{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:14px 16px;margin-bottom:10px}
        .complaint-row:last-child{margin-bottom:0}
        .complaint-subject{font-size:14px;font-weight:700;margin-bottom:4px}
        .complaint-meta{font-size:12px;color:var(--text-faint);margin-bottom:8px}
        .complaint-msg{font-size:13px;color:var(--text-muted);line-height:1.6}
        .complaint-reply{margin-top:10px;padding:10px 14px;background:#fff;border-radius:10px;border:1px solid var(--border);font-size:13px}
        ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
    </style>
</head>
<body>
<nav>
    <a class="nav-logo" href="/">🛍️ <span>Shop</span>Easy</a>
    <div class="nav-actions">
        <a href="/" class="nav-btn btn-outline">🏪 Shop</a>
        <a href="/logout" class="nav-btn btn-danger">→ Logout</a>
    </div>
</nav>

<div class="page">

    <% if (typeof query !== 'undefined' && query && query.complaint === 'raised') { %>
    <div class="alert alert-success">✅ Your complaint has been submitted. Our team will review it shortly.</div>
    <% } %>

    <!-- Profile Hero -->
    <div class="profile-hero">
        <div class="profile-banner"></div>
        <div class="profile-main">
            <div class="avatar-wrap">
                <div class="avatar"><%= user.email.charAt(0).toUpperCase() %></div>
                <div class="avatar-status"></div>
            </div>
            <div class="profile-info">
                <div class="profile-name"><%= user.email.split('@')[0] %></div>
                <div class="profile-email"><%= user.email %></div>
                <div class="profile-role">✅ Verified Customer</div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <%
        var totalSpent = orders.reduce(function(s, o){ return s + (o.total || 0); }, 0);
        var pendingCount = orders.filter(function(o){ return o.status === 'Pending' || o.status === 'In Process'; }).length;
    %>
    <div class="stats-row">
        <div class="stat-card" style="--stat-clr:#ff6b35">
            <div class="stat-em">📦</div>
            <div class="stat-num"><%= orders.length %></div>
            <div class="stat-lbl">Total Orders</div>
        </div>
        <div class="stat-card" style="--stat-clr:#3b82f6">
            <div class="stat-em">⏳</div>
            <div class="stat-num"><%= pendingCount %></div>
            <div class="stat-lbl">Active Orders</div>
        </div>
        <div class="stat-card" style="--stat-clr:#22c55e">
            <div class="stat-em">⭐</div>
            <div class="stat-num">4.8</div>
            <div class="stat-lbl">My Rating</div>
        </div>
        <div class="stat-card" style="--stat-clr:#f59e0b">
            <div class="stat-em">💰</div>
            <div class="stat-num">₹<%= totalSpent.toLocaleString('en-IN') %></div>
            <div class="stat-lbl">Total Spent</div>
        </div>
    </div>

    <!-- Orders -->
    <div class="panel">
        <div class="panel-head"><span>📦</span><h3>My Orders (<%= orders.length %>)</h3></div>
        <div class="panel-body">
            <% if (orders.length === 0) { %>
            <div style="text-align:center;padding:40px 20px;color:var(--text-faint)">
                <div style="font-size:2.5rem;margin-bottom:12px">📦</div>
                <p style="margin-bottom:18px">No orders yet. Start shopping!</p>
                <a href="/" style="display:inline-flex;align-items:center;gap:7px;background:var(--primary);color:#fff;text-decoration:none;padding:12px 24px;border-radius:12px;font-size:14px;font-weight:700">🛍️ Go to Shop</a>
            </div>
            <% } else { %>
            <% orders.forEach(function(order) { %>
            <%
                var sbMap = { 'Pending':'badge-orange','In Process':'badge-blue','Out for Delivery':'badge-purple','Delivered':'badge-green','Cancelled':'badge-red' };
                var pmIcons = { upi:'📱 UPI', card:'💳 Card', wallet:'👛 Wallet', cod:'💵 COD' };
            %>
            <div class="order-row">
                <div class="order-top">
                    <div>
                        <div class="order-id-lbl">Order #<%= order.orderId %></div>
                        <div class="order-date"><%= new Date(order.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></div>
                    </div>
                    <div class="order-badges">
                        <span class="badge <%= sbMap[order.status] || 'badge-gray' %>"><%= order.status %></span>
                        <span class="badge badge-gray"><%= pmIcons[order.payment] || order.payment %></span>
                    </div>
                </div>
                <div class="order-items-list">
                    <% order.items.forEach(function(item){ %>
                    <span class="order-item-chip"><%= item.name %> ×<%= item.qty %></span>
                    <% }); %>
                </div>
                <div class="order-footer">
                    <div class="order-total">₹<%= Number(order.total).toLocaleString('en-IN') %></div>
                    <div class="order-actions">
                        <a href="/my-orders/<%= order._id %>/invoice" class="action-btn">🧾 View Invoice</a>
                        <% if (order.status === 'Delivered') { %>
                        <button class="action-btn danger" onclick="openIssue('<%= order._id %>','<%= order.orderId %>')">🚨 Raise Issue</button>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
            <% } %>
        </div>
    </div>

    <!-- Account Details -->
    <div class="panel">
        <div class="panel-head"><span>👤</span><h3>Account Details</h3></div>
        <div class="panel-body">
            <div class="detail-row"><span class="detail-label">Username</span><span class="detail-value"><%= user.email.split('@')[0] %></span></div>
            <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value"><%= user.email %></span></div>
            <div class="detail-row"><span class="detail-label">Account Type</span><span style="background:var(--primary-pale);border:1px solid rgba(255,107,53,.2);color:var(--primary);font-size:12px;font-weight:700;padding:3px 11px;border-radius:100px;">🛍️ Customer</span></div>
            <div class="detail-row"><span class="detail-label">Status</span><span style="background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.25);color:#15803d;font-size:12px;font-weight:700;padding:3px 11px;border-radius:100px;">✅ Active</span></div>
            <div class="detail-row"><span class="detail-label">Member Since</span><span class="detail-value">2026</span></div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="panel">
        <div class="panel-head"><span>⚡</span><h3>Quick Actions</h3></div>
        <div class="panel-body">
            <div class="actions-grid">
                <a href="/" class="action-tile"><div class="tile-icon">🛍️</div><div><div class="tile-text">Browse Shop</div><div class="tile-sub">Explore products</div></div></a>
                <a href="/checkout" class="action-tile"><div class="tile-icon">🛒</div><div><div class="tile-text">Checkout</div><div class="tile-sub">Complete your order</div></div></a>
                <a href="#" class="action-tile" onclick="openFeedback(event)"><div class="tile-icon">⭐</div><div><div class="tile-text">Leave Feedback</div><div class="tile-sub">Rate your experience</div></div></a>
                <a href="/logout" class="action-tile"><div class="tile-icon">🚪</div><div><div class="tile-text">Sign Out</div><div class="tile-sub">Logout securely</div></div></a>
            </div>
        </div>
    </div>

    <!-- Complaints -->
    <% if (complaints && complaints.length > 0) { %>
    <div class="panel">
        <div class="panel-head"><span>🚨</span><h3>My Complaints (<%= complaints.length %>)</h3></div>
        <div class="panel-body">
            <% complaints.forEach(function(c){ %>
            <div class="complaint-row">
                <div class="complaint-subject"><%= c.subject %></div>
                <div class="complaint-meta">Order #<%= c.orderId %> &nbsp;·&nbsp; <span class="badge <%= c.status==='Resolved'?'badge-green':c.status==='In Review'?'badge-blue':'badge-orange' %>"><%= c.status %></span></div>
                <div class="complaint-msg"><%= c.message %></div>
                <% if (c.adminReply) { %>
                <div class="complaint-reply"><strong>📨 ShopEasy Reply:</strong> <%= c.adminReply %></div>
                <% } %>
            </div>
            <% }); %>
        </div>
    </div>
    <% } %>

</div>

<!-- RAISE ISSUE MODAL -->
<div class="modal-overlay" id="issue-modal">
    <div class="modal-box">
        <div class="modal-head">
            <h3>🚨 Raise an Issue</h3>
            <button class="modal-close" onclick="closeIssue()">✕</button>
        </div>
        <form id="issue-form" method="POST" class="modal-body">
            <div class="fg">
                <label>Subject *</label>
                <select name="subject" required>
                    <option value="">Select issue type</option>
                    <option>Item not received</option>
                    <option>Wrong item delivered</option>
                    <option>Damaged product</option>
                    <option>Quality issue</option>
                    <option>Refund not received</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="fg">
                <label>Describe the issue *</label>
                <textarea name="message" placeholder="Please describe your issue in detail…" required></textarea>
            </div>
            <button type="submit" class="btn-submit">📨 Submit Complaint</button>
        </form>
    </div>
</div>

<!-- FEEDBACK MODAL -->
<div class="modal-overlay" id="feedback-modal">
    <div class="modal-box">
        <div class="modal-head">
            <h3>⭐ Leave Feedback</h3>
            <button class="modal-close" onclick="closeFeedback()">✕</button>
        </div>
        <form action="/feedback" method="POST" class="modal-body">
            <div class="fg">
                <label>Rating *</label>
                <select name="rating" required>
                    <option value="">Select rating</option>
                    <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                    <option value="4">⭐⭐⭐⭐ Good</option>
                    <option value="3">⭐⭐⭐ Average</option>
                    <option value="2">⭐⭐ Poor</option>
                    <option value="1">⭐ Very Poor</option>
                </select>
            </div>
            <div class="fg">
                <label>Your feedback *</label>
                <textarea name="message" placeholder="Share your shopping experience…" required></textarea>
            </div>
            <button type="submit" class="btn-submit">⭐ Submit Feedback</button>
        </form>
    </div>
</div>

<script>
    function openIssue(orderId, orderStrId) {
        document.getElementById('issue-form').action = '/orders/' + orderId + '/raise-issue';
        document.getElementById('issue-modal').classList.add('open');
    }
    function closeIssue() { document.getElementById('issue-modal').classList.remove('open'); }
    function openFeedback(e) { e.preventDefault(); document.getElementById('feedback-modal').classList.add('open'); }
    function closeFeedback() { document.getElementById('feedback-modal').classList.remove('open'); }

    // Close modals on backdrop click
    document.getElementById('issue-modal').addEventListener('click', function(e){ if(e.target===this) closeIssue(); });
    document.getElementById('feedback-modal').addEventListener('click', function(e){ if(e.target===this) closeFeedback(); });
    document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ closeIssue(); closeFeedback(); } });
</script>
</body>
</html>