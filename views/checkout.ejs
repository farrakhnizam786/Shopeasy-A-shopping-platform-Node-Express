<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | Checkout</title>
    <meta name="description" content="Securely complete your order at ShopEasy.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #ff6b35; --primary-dark: #e55a25; --primary-light: #ff8c5c;
            --success: #22c55e; --danger: #ef4444;
            --bg: #fff; --surface: #f8f9fa; --surface2: #f0f2f5; --border: #e5e7eb;
            --text: #111827; --text-muted: #6b7280; --text-faint: #9ca3af;
            --shadow: 0 2px 12px rgba(0,0,0,0.08); --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
        nav {
            position: sticky; top: 0; z-index: 100; height: 64px; padding: 0 5%;
            display: flex; align-items: center; justify-content: space-between;
            background: #fff; border-bottom: 1px solid var(--border); box-shadow: var(--shadow);
        }
        .nav-logo { font-size: 1.3rem; font-weight: 900; text-decoration: none; color: var(--primary); display: flex; align-items: center; gap: 8px; }
        .nav-logo span { color: var(--text); }
        .nav-back { padding: 8px 20px; border-radius: 10px; font-size: 13px; font-weight: 700; border: 1.5px solid var(--border); background: #fff; color: var(--text-muted); cursor: pointer; text-decoration: none; transition: .2s; }
        .nav-back:hover { border-color: var(--primary); color: var(--primary); }
        .progress-bar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 14px 5%; display: flex; align-items: center; justify-content: center; gap: 0; }
        .step { display: flex; align-items: center; gap: 8px; }
        .step-dot { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; border: 2px solid var(--border); background: #fff; color: var(--text-faint); }
        .step.active .step-dot { background: var(--primary); border-color: var(--primary); color: #fff; }
        .step.done .step-dot { background: var(--success); border-color: var(--success); color: #fff; }
        .step-label { font-size: 12px; font-weight: 600; color: var(--text-faint); }
        .step.active .step-label { color: var(--primary); }
        .step.done .step-label { color: var(--success); }
        .step-line { width: 60px; height: 2px; background: var(--border); margin: 0 4px; }
        .step-line.done { background: var(--success); }

        .page { max-width: 1100px; margin: 0 auto; padding: 32px 5% 80px; display: grid; grid-template-columns: 1fr 380px; gap: 28px; }
        @media(max-width: 820px) { .page { grid-template-columns: 1fr; } }

        .form-panel { display: flex; flex-direction: column; gap: 20px; }
        .panel { background: #fff; border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        .panel-head { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; background: linear-gradient(135deg, #fff7f4, #fff); }
        .panel-head-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--primary), var(--primary-light)); display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #fff; flex-shrink: 0; }
        .panel-head h3 { font-size: .95rem; font-weight: 800; }
        .panel-head p { font-size: 12px; color: var(--text-muted); margin-top: 1px; }
        .panel-body { padding: 24px; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-grid .full { grid-column: 1 / -1; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group label { font-size: 12.5px; font-weight: 700; color: var(--text); text-transform: uppercase; letter-spacing: .4px; }
        .form-group input, .form-group select { padding: 12px 14px; border: 1.5px solid var(--border); border-radius: 10px; font-size: 14px; font-family: inherit; color: var(--text); background: var(--surface); outline: none; transition: .2s; }
        .form-group input:focus, .form-group select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,107,53,.12); background: #fff; }
        .form-group input::placeholder { color: var(--text-faint); }
        .payment-options { display: flex; flex-direction: column; gap: 10px; }
        .payment-option { border: 2px solid var(--border); border-radius: 14px; padding: 14px 18px; cursor: pointer; transition: .2s; display: flex; align-items: center; gap: 14px; background: var(--surface); }
        .payment-option:hover { border-color: var(--primary); background: rgba(255,107,53,.04); }
        .payment-option.selected { border-color: var(--primary); background: rgba(255,107,53,.06); box-shadow: 0 0 0 3px rgba(255,107,53,.1); }
        .payment-option input[type="radio"] { accent-color: var(--primary); width: 18px; height: 18px; flex-shrink: 0; }
        .po-icon { font-size: 1.6rem; }
        .po-info { flex: 1; }
        .po-name { font-size: 14px; font-weight: 700; }
        .po-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
        .po-badge { padding: 3px 10px; border-radius: 100px; font-size: 11px; font-weight: 700; background: rgba(34,197,94,.12); color: #16a34a; border: 1px solid rgba(34,197,94,.25); }
        .summary-panel { position: sticky; top: 80px; display: flex; flex-direction: column; gap: 16px; }
        .summary-card { background: #fff; border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        .summary-head { padding: 16px 20px; border-bottom: 1px solid var(--border); background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; }
        .summary-head h3 { font-size: .9rem; font-weight: 800; }
        .summary-head p { font-size: 11px; opacity: .8; margin-top: 2px; }
        .summary-body { padding: 16px 20px; }
        .summary-items { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; max-height: 240px; overflow-y: auto; }
        .si { display: flex; align-items: center; gap: 10px; padding: 8px; background: var(--surface); border-radius: 12px; }
        .si-img { width: 44px; height: 44px; border-radius: 8px; object-fit: cover; flex-shrink: 0; background: var(--surface2); }
        .si-info { flex: 1; overflow: hidden; }
        .si-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .si-qty { font-size: 11.5px; color: var(--text-muted); }
        .si-price { font-size: 13px; font-weight: 800; color: var(--primary); flex-shrink: 0; }
        .divider { height: 1px; background: var(--border); margin: 12px 0; }
        .total-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .total-row span:first-child { font-size: 13px; color: var(--text-muted); }
        .total-row span:last-child { font-size: 14px; font-weight: 700; }
        .total-row.grand span:first-child { font-size: 14px; font-weight: 700; color: var(--text); }
        .total-row.grand span:last-child { font-size: 1.4rem; font-weight: 900; color: var(--primary); }
        .free-ship { display: flex; align-items: center; gap: 6px; background: rgba(34,197,94,.08); border: 1px solid rgba(34,197,94,.2); color: #15803d; border-radius: 10px; padding: 8px 12px; font-size: 12px; font-weight: 700; margin-bottom: 14px; }
        .place-btn { width: 100%; padding: 16px; border-radius: 14px; border: none; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; font-size: 1rem; font-weight: 800; font-family: inherit; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 6px 20px rgba(255,107,53,.4); transition: .25s; }
        .place-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255,107,53,.55); }
        .place-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }
        .secure-note { text-align: center; font-size: 11.5px; color: var(--text-faint); margin-top: 10px; }
        #toast-wrap { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 2000; pointer-events: none; }
        .toast { background: var(--text); color: #fff; padding: 11px 20px; border-radius: 12px; font-size: 13.5px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: var(--shadow-lg); animation: tIn .3s ease; }
        @keyframes tIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
    </style>
</head>
<body>
<nav>
    <a class="nav-logo" href="/">🛍️ <span>Shop</span>Easy</a>
    <a href="/" class="nav-back">← Back to Shop</a>
</nav>
<div class="progress-bar">
    <div class="step done"><div class="step-dot">✓</div><div class="step-label">Cart</div></div>
    <div class="step-line done"></div>
    <div class="step active"><div class="step-dot">2</div><div class="step-label">Checkout</div></div>
    <div class="step-line"></div>
    <div class="step"><div class="step-dot">3</div><div class="step-label">Confirmation</div></div>
</div>

<div class="page">
    <div class="form-panel">

        <!-- Delivery Address -->
        <div class="panel">
            <div class="panel-head">
                <div class="panel-head-icon">📍</div>
                <div><h3>Delivery Address</h3><p>Where should we deliver your order?</p></div>
            </div>
            <div class="panel-body">
                <div class="form-grid">
                    <div class="form-group"><label>Full Name *</label><input type="text" id="f-name" placeholder="e.g. Ravi Kumar"></div>
                    <div class="form-group"><label>Phone Number *</label><input type="tel" id="f-phone" placeholder="10-digit mobile" maxlength="10"></div>
                    <div class="form-group full"><label>Email Address *</label><input type="email" id="f-email" placeholder="yourname@email.com"></div>
                    <div class="form-group full"><label>Street / Flat / Area *</label><input type="text" id="f-street" placeholder="Flat no., building, street"></div>
                    <div class="form-group"><label>City *</label><input type="text" id="f-city" placeholder="e.g. Mumbai"></div>
                    <div class="form-group"><label>State *</label>
                        <select id="f-state">
                            <option value="">Select State</option>
                            <option>Andhra Pradesh</option><option>Delhi</option><option>Gujarat</option>
                            <option>Karnataka</option><option>Kerala</option><option>Madhya Pradesh</option>
                            <option>Maharashtra</option><option>Punjab</option><option>Rajasthan</option>
                            <option>Tamil Nadu</option><option>Telangana</option><option>Uttar Pradesh</option><option>West Bengal</option>
                        </select>
                    </div>
                    <div class="form-group"><label>PIN Code *</label><input type="text" id="f-pin" placeholder="6-digit PIN" maxlength="6"></div>
                    <div class="form-group"><label>Landmark (Optional)</label><input type="text" id="f-landmark" placeholder="Near temple, park…"></div>
                </div>
            </div>
        </div>

        <!-- Payment Method -->
        <div class="panel">
            <div class="panel-head">
                <div class="panel-head-icon">💳</div>
                <div><h3>Payment Method</h3><p>All payments are 100% secure</p></div>
            </div>
            <div class="panel-body">
                <div class="payment-options">
                    <label class="payment-option selected" id="opt-upi" onclick="selectPayment('upi')">
                        <input type="radio" name="payment" value="upi" checked>
                        <div class="po-icon">📱</div>
                        <div class="po-info"><div class="po-name">UPI Payment</div><div class="po-sub">GPay, PhonePe, Paytm, BHIM</div></div>
                        <span class="po-badge">Popular</span>
                    </label>
                    <label class="payment-option" id="opt-card" onclick="selectPayment('card')">
                        <input type="radio" name="payment" value="card">
                        <div class="po-icon">💳</div>
                        <div class="po-info"><div class="po-name">Debit / Credit Card</div><div class="po-sub">Visa, Mastercard, Rupay, Amex</div></div>
                    </label>
                    <label class="payment-option" id="opt-wallet" onclick="selectPayment('wallet')">
                        <input type="radio" name="payment" value="wallet">
                        <div class="po-icon">👛</div>
                        <div class="po-info"><div class="po-name">Wallet / Net Banking</div><div class="po-sub">Paytm Wallet, Mobikwik, Net Banking</div></div>
                    </label>
                    <label class="payment-option" id="opt-cod" onclick="selectPayment('cod')">
                        <input type="radio" name="payment" value="cod">
                        <div class="po-icon">💵</div>
                        <div class="po-info"><div class="po-name">Cash on Delivery</div><div class="po-sub">Pay when your order arrives</div></div>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Summary -->
    <div class="summary-panel">
        <div class="summary-card">
            <div class="summary-head"><h3>🛒 Order Summary</h3><p id="item-count-label">Loading…</p></div>
            <div class="summary-body">
                <div class="summary-items" id="summary-items"><p style="color:var(--text-faint);font-size:13px;text-align:center;padding:20px 0">Cart is empty.</p></div>
                <div class="free-ship">🚚 FREE Delivery on this order!</div>
                <div class="total-row"><span>Subtotal</span><span id="sub-total">₹0</span></div>
                <div class="total-row"><span>Delivery</span><span style="color:var(--success);font-weight:700;">FREE</span></div>
                <div class="total-row"><span>GST (18%)</span><span id="gst-total">₹0</span></div>
                <div class="divider"></div>
                <div class="total-row grand"><span>You Pay</span><span id="grand-total">₹0</span></div>
            </div>
        </div>
        <button class="place-btn" id="place-btn" onclick="placeOrder()">🔒 Confirm & Place Order</button>
        <p class="secure-note">🔐 SSL Encrypted · 100% Secure</p>
    </div>
</div>

<div id="toast-wrap"></div>

<script>
    var cart = [];
    try { cart = JSON.parse(sessionStorage.getItem('shopeasy_cart') || '[]'); } catch(e){}

    function fmt(n) { return '₹' + Number(n).toLocaleString('en-IN'); }

    function render() {
        var items = document.getElementById('summary-items');
        var subEl = document.getElementById('sub-total');
        var gstEl = document.getElementById('gst-total');
        var grandEl = document.getElementById('grand-total');
        var countEl = document.getElementById('item-count-label');
        if (!cart.length) {
            items.innerHTML = '<p style="color:var(--text-faint);font-size:13px;text-align:center;padding:20px 0">Cart is empty.</p>';
            subEl.textContent = '₹0'; gstEl.textContent = '₹0'; grandEl.textContent = '₹0';
            countEl.textContent = '0 items'; return;
        }
        var totalQty = cart.reduce(function(s,i){return s+i.qty;},0);
        countEl.textContent = totalQty + ' item' + (totalQty>1?'s':'');
        items.innerHTML = '';
        cart.forEach(function(item) {
            var d = document.createElement('div'); d.className = 'si';
            d.innerHTML = '<img class="si-img" src="'+(item.img||'https://placehold.co/44x44/f8f9fa/ff6b35?text=P')+'" onerror="this.src=\'https://placehold.co/44x44/f8f9fa/ff6b35?text=P\'" alt="">' +
                '<div class="si-info"><div class="si-name">'+item.name+'</div><div class="si-qty">Qty: '+item.qty+'</div></div>' +
                '<div class="si-price">'+fmt(item.price * item.qty)+'</div>';
            items.appendChild(d);
        });
        var sub = cart.reduce(function(s,i){return s+i.price*i.qty;},0);
        var gst = Math.round(sub * 0.18);
        var grand = sub + gst;
        subEl.textContent = fmt(sub); gstEl.textContent = fmt(gst); grandEl.textContent = fmt(grand);
    }
    render();

    function selectPayment(mode) {
        document.querySelectorAll('.payment-option').forEach(function(el){ el.classList.remove('selected'); });
        document.getElementById('opt-'+mode).classList.add('selected');
        document.querySelector('#opt-'+mode+' input').checked = true;
    }

    function showToast(msg) {
        var w = document.getElementById('toast-wrap');
        var t = document.createElement('div'); t.className = 'toast'; t.textContent = msg;
        w.appendChild(t);
        setTimeout(function(){ t.remove(); }, 3000);
    }

    function placeOrder() {
        var name  = document.getElementById('f-name').value.trim();
        var phone = document.getElementById('f-phone').value.trim();
        var email = document.getElementById('f-email').value.trim();
        var street = document.getElementById('f-street').value.trim();
        var city  = document.getElementById('f-city').value.trim();
        var state = document.getElementById('f-state').value;
        var pin   = document.getElementById('f-pin').value.trim();
        var payment = document.querySelector('input[name="payment"]:checked')?.value || 'upi';

        if (!name)                    { showToast('⚠️ Enter your full name'); return; }
        if (!/^\d{10}$/.test(phone))  { showToast('⚠️ Enter valid 10-digit phone'); return; }
        if (!email.includes('@'))     { showToast('⚠️ Enter valid email'); return; }
        if (!street)                  { showToast('⚠️ Enter street address'); return; }
        if (!city)                    { showToast('⚠️ Enter city'); return; }
        if (!state)                   { showToast('⚠️ Select state'); return; }
        if (!/^\d{6}$/.test(pin))     { showToast('⚠️ Enter valid 6-digit PIN'); return; }
        if (!cart.length)             { showToast('⚠️ Your cart is empty!'); return; }

        var sub   = cart.reduce(function(s,i){return s+i.price*i.qty;},0);
        var gst   = Math.round(sub * 0.18);
        var grand = sub + gst;

        var btn = document.getElementById('place-btn');
        btn.disabled = true; btn.textContent = '⏳ Placing Order…';

        fetch('/place-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                items:    JSON.stringify(cart),
                address:  JSON.stringify({ name, phone, email, street, city, state, pin, landmark: document.getElementById('f-landmark').value.trim() }),
                payment, subtotal: sub, gst, total: grand
            })
        })
        .then(function(r){ return r.json(); })
        .then(function(data){
            if (data.success) {
                sessionStorage.removeItem('shopeasy_cart');
                window.location.href = '/order-success/' + data.orderId;
            } else {
                showToast('❌ ' + (data.error || 'Order failed. Please try again.'));
                btn.disabled = false; btn.textContent = '🔒 Confirm & Place Order';
            }
        })
        .catch(function(){
            showToast('❌ Network error. Please try again.');
            btn.disabled = false; btn.textContent = '🔒 Confirm & Place Order';
        });
    }
</script>
</body>
</html>
