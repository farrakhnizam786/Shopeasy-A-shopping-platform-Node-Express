<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | My Account</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f0f1a;
            --surface: #1a1a2e;
            --surface2: #1e1e3a;
            --border: rgba(255,255,255,0.07);
            --primary: #7c3aed;
            --primary-light: #a78bfa;
            --accent: #0ea5e9;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --text-faint: #475569;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* Background blobs */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse 60% 40% at 10% 5%, rgba(124,58,237,.15) 0%, transparent 55%),
                radial-gradient(ellipse 50% 35% at 90% 95%, rgba(14,165,233,.12) 0%, transparent 55%);
            pointer-events: none; z-index: 0;
        }

        /* ─── NAV ─── */
        nav {
            position: sticky; top: 0; z-index: 100;
            height: 64px; padding: 0 5%;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(15,15,26,.85); backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .nav-logo {
            font-size: 1.25rem; font-weight: 900; cursor: pointer;
            background: linear-gradient(135deg, var(--primary-light), #60a5fa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            display: flex; align-items: center; gap: 8px; text-decoration: none;
        }
        .nav-logo-icon {
            width: 30px; height: 30px; border-radius: 8px;
            background: linear-gradient(135deg, var(--primary), #0ea5e9);
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem;
        }
        .nav-actions { display: flex; align-items: center; gap: 10px; }
        .nav-btn {
            padding: 8px 18px; border-radius: 10px; font-size: 13px; font-weight: 700;
            font-family: 'Inter', sans-serif; cursor: pointer; text-decoration: none;
            transition: all .2s;
        }
        .btn-outline {
            background: transparent; border: 1px solid var(--border); color: var(--text-muted);
        }
        .btn-outline:hover { border-color: rgba(255,255,255,.2); color: var(--text); }
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #5b21b6);
            border: none; color: #fff;
            box-shadow: 0 4px 12px rgba(124,58,237,.35);
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(124,58,237,.5); }
        .btn-danger {
            background: transparent; border: 1px solid rgba(239,68,68,.3);
            color: #f87171;
        }
        .btn-danger:hover { background: rgba(239,68,68,.1); border-color: #ef4444; color: #ef4444; }

        /* ─── MAIN LAYOUT ─── */
        .page {
            max-width: 900px; margin: 0 auto;
            padding: 40px 5% 80px;
            position: relative; z-index: 1;
        }

        /* ─── PROFILE HERO ─── */
        .profile-hero {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px; overflow: hidden;
            margin-bottom: 24px;
            position: relative;
        }

        /* Banner strip */
        .profile-banner {
            height: 100px;
            background: linear-gradient(135deg, #7c3aed 0%, #0ea5e9 50%, #10b981 100%);
            position: relative;
        }
        .profile-banner::after {
            content: '';
            position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .profile-main {
            padding: 0 28px 28px;
            display: flex; align-items: flex-end; gap: 20px;
            margin-top: -40px;
            flex-wrap: wrap;
        }

        .avatar-wrap { position: relative; flex-shrink: 0; }
        .avatar {
            width: 80px; height: 80px; border-radius: 22px;
            background: linear-gradient(135deg, var(--primary), #ec4899);
            border: 4px solid var(--surface);
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; font-weight: 900; color: #fff;
            box-shadow: 0 8px 24px rgba(124,58,237,.4);
        }
        .avatar-status {
            position: absolute; bottom: 4px; right: -2px;
            width: 16px; height: 16px; border-radius: 50%;
            background: var(--success); border: 3px solid var(--surface);
        }

        .profile-info { flex: 1; min-width: 200px; padding-top: 44px; }
        .profile-name { font-size: 1.3rem; font-weight: 900; letter-spacing: -0.4px; }
        .profile-email { font-size: 13px; color: var(--text-muted); margin-top: 3px; }
        .profile-role {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.25);
            color: #34d399; font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 100px; margin-top: 8px;
            letter-spacing: 0.4px;
        }

        /* ─── STATS ROW ─── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 14px; margin-bottom: 24px;
        }
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px; padding: 20px;
            display: flex; flex-direction: column; gap: 8px;
            position: relative; overflow: hidden;
            transition: transform .25s, border-color .25s;
        }
        .stat-card:hover { transform: translateY(-3px); border-color: rgba(124,58,237,.25); }
        .stat-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
            background: var(--stat-clr, var(--primary)); border-radius: 18px 18px 0 0;
        }
        .stat-em { font-size: 1.3rem; }
        .stat-num { font-size: 1.7rem; font-weight: 900; line-height: 1; }
        .stat-lbl { font-size: 11.5px; color: var(--text-faint); font-weight: 600; }

        /* ─── PANELS ─── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px; overflow: hidden;
            margin-bottom: 20px;
        }
        .panel-head {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 10px;
        }
        .panel-head h3 { font-size: .95rem; font-weight: 800; }
        .panel-body { padding: 20px; }

        /* ─── ACCOUNT DETAILS ─── */
        .detail-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
        }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { font-size: 12.5px; color: var(--text-faint); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .detail-value { font-size: 14px; font-weight: 600; color: var(--text); }
        .badge {
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 12px; font-weight: 700; padding: 3px 11px; border-radius: 100px;
        }
        .badge-green { background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.25); color: #34d399; }
        .badge-blue  { background: rgba(14,165,233,.12); border: 1px solid rgba(14,165,233,.25); color: #38bdf8; }

        /* ─── QUICK ACTIONS ─── */
        .actions-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
        }
        .action-tile {
            background: var(--surface2); border: 1px solid var(--border);
            border-radius: 14px; padding: 18px 16px;
            text-decoration: none; color: var(--text-muted);
            display: flex; align-items: center; gap: 12px;
            transition: all .25s; cursor: pointer;
        }
        .action-tile:hover { border-color: rgba(124,58,237,.3); color: var(--text); transform: translateY(-2px); background: rgba(124,58,237,.06); }
        .action-tile .tile-icon {
            width: 42px; height: 42px; border-radius: 12px;
            background: rgba(255,255,255,.05);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.15rem; flex-shrink: 0;
        }
        .tile-text { font-size: 13.5px; font-weight: 700; }
        .tile-sub  { font-size: 11.5px; color: var(--text-faint); margin-top: 2px; }

        /* ─── EMPTY ORDERS ─── */
        .empty-orders {
            text-align: center; padding: 32px 20px;
            color: var(--text-faint);
        }
        .empty-orders .em { font-size: 2.5rem; opacity: .35; margin-bottom: 10px; }
        .empty-orders p { font-size: 14px; margin-bottom: 18px; }
        .btn-shop-link {
            display: inline-flex; align-items: center; gap: 7px;
            background: linear-gradient(135deg, var(--primary), #5b21b6);
            color: #fff; text-decoration: none;
            padding: 11px 24px; border-radius: 12px;
            font-size: 14px; font-weight: 700;
            box-shadow: 0 4px 14px rgba(124,58,237,.35);
            transition: transform .2s, box-shadow .2s;
        }
        .btn-shop-link:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(124,58,237,.5); }

        /* ─── SCROLLBAR ─── */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    </style>
</head>
<body>

<!-- ═══ NAV ═══ -->
<nav>
    <a class="nav-logo" href="/">
        <div class="nav-logo-icon">⚡</div>
        ShopEasy
    </a>
    <div class="nav-actions">
        <a href="/" class="nav-btn btn-outline">🛍️ Shop</a>
        <a href="/logout" class="nav-btn btn-danger">Logout</a>
    </div>
</nav>

<!-- ═══ PAGE ═══ -->
<div class="page">

    <!-- Profile Hero -->
    <div class="profile-hero">
        <div class="profile-banner"></div>
        <div class="profile-main">
            <div class="avatar-wrap">
                <div class="avatar"><%= user.email.charAt(0).toUpperCase() %></div>
                <div class="avatar-status"></div>
            </div>
            <div class="profile-info">
                <div class="profile-name"><%= user.email.split('@')[0] %></div>
                <div class="profile-email"><%= user.email %></div>
                <div class="profile-role">✅ Verified Customer</div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card" style="--stat-clr:#7c3aed">
            <div class="stat-em">📦</div>
            <div class="stat-num">0</div>
            <div class="stat-lbl">Total Orders</div>
        </div>
        <div class="stat-card" style="--stat-clr:#0ea5e9">
            <div class="stat-em">🛒</div>
            <div class="stat-num">0</div>
            <div class="stat-lbl">Items in Cart</div>
        </div>
        <div class="stat-card" style="--stat-clr:#10b981">
            <div class="stat-em">⭐</div>
            <div class="stat-num">4.8</div>
            <div class="stat-lbl">My Rating</div>
        </div>
        <div class="stat-card" style="--stat-clr:#f59e0b">
            <div class="stat-em">💰</div>
            <div class="stat-num">₹0</div>
            <div class="stat-lbl">Total Spent</div>
        </div>
    </div>

    <!-- Account Details -->
    <div class="panel">
        <div class="panel-head">
            <span>👤</span>
            <h3>Account Details</h3>
        </div>
        <div class="panel-body">
            <div class="detail-row">
                <span class="detail-label">Username</span>
                <span class="detail-value"><%= user.email.split('@')[0] %></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Email Address</span>
                <span class="detail-value"><%= user.email %></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Account Type</span>
                <span class="badge badge-green">🛍️ Customer</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Account Status</span>
                <span class="badge badge-blue">✅ Active</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Member Since</span>
                <span class="detail-value">2026</span>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="panel">
        <div class="panel-head">
            <span>⚡</span>
            <h3>Quick Actions</h3>
        </div>
        <div class="panel-body">
            <div class="actions-grid">
                <a href="/" class="action-tile">
                    <div class="tile-icon">🛍️</div>
                    <div>
                        <div class="tile-text">Browse Shop</div>
                        <div class="tile-sub">Explore products</div>
                    </div>
                </a>
                <a href="/" class="action-tile">
                    <div class="tile-icon">🛒</div>
                    <div>
                        <div class="tile-text">My Cart</div>
                        <div class="tile-sub">View saved items</div>
                    </div>
                </a>
                <a href="/" class="action-tile">
                    <div class="tile-icon">📦</div>
                    <div>
                        <div class="tile-text">My Orders</div>
                        <div class="tile-sub">Track deliveries</div>
                    </div>
                </a>
                <a href="/logout" class="action-tile">
                    <div class="tile-icon">🚪</div>
                    <div>
                        <div class="tile-text">Sign Out</div>
                        <div class="tile-sub">Logout securely</div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Recent Activity / Orders -->
    <div class="panel">
        <div class="panel-head">
            <span>🕒</span>
            <h3>Recent Orders</h3>
        </div>
        <div class="panel-body">
            <div class="empty-orders">
                <div class="em">📦</div>
                <p>You haven't placed any orders yet.<br>Start shopping to see your orders here!</p>
                <a href="/" class="btn-shop-link">🛍️ Go to Shop</a>
            </div>
        </div>
    </div>

</div><!-- /page -->

</body>
</html>