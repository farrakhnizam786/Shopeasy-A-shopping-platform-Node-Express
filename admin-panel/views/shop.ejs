<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopEasy | Premium Store</title>
    <meta name="description" content="Shop the best products at ShopEasy — your premium online destination.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Lucide icons via unpkg (whitelisted in CSP) -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <style>
        /* ============ TOKENS ============ */
        :root {
            --primary: #7c3aed;
            --primary-light: #a78bfa;
            --primary-dark: #5b21b6;
            --accent: #f59e0b;
            --success: #10b981;
            --danger: #ef4444;
            --bg: #0f0f1a;
            --bg-card: #1a1a2e;
            --bg-card2: #16213e;
            --surface: #1e1e3a;
            --border: rgba(255,255,255,0.08);
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --text-faint: #475569;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
        }
        body::before {
            content: '';
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse 80% 50% at 20% 0%, rgba(124,58,237,.18) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 100%, rgba(14,165,233,.12) 0%, transparent 60%);
            pointer-events: none; z-index: 0;
        }

        /* ============ NAV ============ */
        nav {
            position: sticky; top: 0; z-index: 900;
            height: 68px; padding: 0 5%;
            display: flex; justify-content: space-between; align-items: center;
            background: rgba(15,15,26,.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .nav-logo {
            font-size: 1.4rem; font-weight: 900; cursor: pointer;
            background: linear-gradient(135deg, var(--primary-light), #60a5fa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            display: flex; align-items: center; gap: 8px;
            transition: opacity .2s;
        }
        .nav-logo:hover { opacity: .8; }
        .nav-logo svg { -webkit-text-fill-color: unset; color: var(--primary-light); }
        .nav-actions { display: flex; align-items: center; gap: 8px; }
        .nav-icon-btn {
            background: none; border: 1px solid transparent;
            color: var(--text-muted); cursor: pointer;
            width: 40px; height: 40px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            transition: all .25s; position: relative;
        }
        .nav-icon-btn:hover { background: var(--surface); border-color: var(--border); color: var(--text-main); transform: translateY(-1px); }

        /* Cart badge */
        .cart-count {
            position: absolute; top: 4px; right: 4px;
            background: linear-gradient(135deg, var(--primary), #ec4899);
            color: #fff; font-size: 9px; font-weight: 700;
            width: 16px; height: 16px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid var(--bg);
            transition: transform .3s cubic-bezier(.34,1.56,.64,1);
        }
        .cart-count.bump { transform: scale(1.6); }

        /* Profile button color states */
        #profile-btn { transition: all .35s ease; }
        #profile-btn.c0 { color: #a78bfa; background: rgba(124,58,237,.15); border-color: rgba(124,58,237,.3); }
        #profile-btn.c1 { color: #38bdf8; background: rgba(14,165,233,.15); border-color: rgba(14,165,233,.3); }
        #profile-btn.c2 { color: #34d399; background: rgba(16,185,129,.15); border-color: rgba(16,185,129,.3); }
        #profile-btn.c3 { color: #fbbf24; background: rgba(245,158,11,.15); border-color: rgba(245,158,11,.3); }
        #profile-btn.c4 { color: #f87171; background: rgba(239,68,68,.15); border-color: rgba(239,68,68,.3); }
        #profile-btn.c5 { color: #f472b6; background: rgba(236,72,153,.15); border-color: rgba(236,72,153,.3); }

        /* ============ PROFILE DROPDOWN ============ */
        .profile-wrap { position: relative; }
        .profile-dropdown {
            display: none; position: absolute; right: 0; top: calc(100% + 10px);
            background: var(--bg-card); min-width: 220px;
            box-shadow: 0 16px 40px rgba(0,0,0,.6), 0 0 0 1px var(--border);
            border-radius: 16px; z-index: 999; overflow: hidden;
        }
        .profile-dropdown.open { display: block; animation: dropIn .22s ease; }
        @keyframes dropIn { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }

        .pd-user-card {
            padding: 16px;
            background: linear-gradient(135deg, rgba(124,58,237,.2), rgba(14,165,233,.12));
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 12px;
        }
        .pd-avatar {
            width: 42px; height: 42px; border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), #ec4899);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; font-weight: 800; color: #fff;
            flex-shrink: 0;
        }
        .pd-user-name { font-size: 14px; font-weight: 700; color: var(--text-main); }
        .pd-user-email { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
        .pd-guest-text { font-size: 13px; font-weight: 600; color: var(--text-muted); }

        .profile-dropdown a {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 16px; color: var(--text-muted);
            text-decoration: none; font-size: 13.5px; font-weight: 500;
            transition: .18s;
        }
        .profile-dropdown a:hover { background: var(--surface); color: var(--text-main); }
        .profile-dropdown a.dd-danger { color: #f87171; }
        .profile-dropdown a.dd-danger:hover { background: rgba(239,68,68,.12); color: #ef4444; }
        .pd-divider { height: 1px; background: var(--border); }

        /* ============ HERO ============ */
        .hero { text-align: center; padding: 60px 5% 36px; position: relative; z-index: 1; }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(124,58,237,.15); border: 1px solid rgba(124,58,237,.3);
            color: var(--primary-light); font-size: 12px; font-weight: 600;
            padding: 5px 14px; border-radius: 100px; margin-bottom: 18px;
        }
        .hero h1 {
            font-size: clamp(2rem,5vw,3.4rem); font-weight: 900; letter-spacing: -1.5px; line-height: 1.1;
            background: linear-gradient(135deg, #f1f5f9 30%, #a78bfa 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
            margin-bottom: 14px;
        }
        .hero p { color: var(--text-muted); font-size: 1rem; max-width: 460px; margin: 0 auto 30px; line-height: 1.6; }
        .search-bar {
            display: inline-flex; align-items: center;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 14px; padding: 10px 16px; gap: 10px;
            width: min(400px, 90%); transition: border-color .2s, box-shadow .2s;
        }
        .search-bar:focus-within { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(124,58,237,.2); }
        .search-bar input {
            background: none; border: none; outline: none;
            color: var(--text-main); font-size: .9rem; font-family: inherit; width: 100%;
        }
        .search-bar input::placeholder { color: var(--text-faint); }

        /* ============ FILTER CHIPS ============ */
        .filter-row {
            display: flex; gap: 10px; padding: 0 5% 28px;
            overflow-x: auto; scrollbar-width: none; position: relative; z-index: 1;
        }
        .filter-row::-webkit-scrollbar { display: none; }
        .chip {
            flex-shrink: 0; padding: 7px 18px; border-radius: 100px;
            font-size: 13px; font-weight: 600; cursor: pointer;
            border: 1px solid var(--border); background: var(--surface); color: var(--text-muted);
            transition: .2s;
        }
        .chip:hover, .chip.active { background: var(--primary); border-color: var(--primary); color: #fff; }

        /* ============ PRODUCT GRID ============ */
        .products-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 22px; padding: 0 5% 80px; max-width: 1400px; margin: 0 auto; position: relative; z-index: 1;
        }
        .product-card {
            background: var(--bg-card); border-radius: 20px; border: 1px solid var(--border);
            overflow: hidden; display: flex; flex-direction: column; position: relative;
            cursor: pointer; opacity: 0; transform: translateY(24px);
            transition: opacity .5s ease, transform .5s ease, box-shadow .3s, border-color .3s;
        }
        .product-card:hover { transform: translateY(-6px) !important; box-shadow: 0 24px 48px rgba(0,0,0,.4); border-color: rgba(124,58,237,.35); }
        .product-badge {
            position: absolute; top: 12px; left: 12px; z-index: 2;
            background: linear-gradient(135deg, var(--primary), #ec4899);
            color: #fff; font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 100px;
        }
        .img-container { width: 100%; height: 180px; overflow: hidden; background: var(--surface); }
        .product-card img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; display: block; }
        .product-card:hover img { transform: scale(1.1); }
        .product-info { padding: 14px; display: flex; flex-direction: column; flex: 1; }
        .product-info h3 { font-size: .95rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
        .card-cat-badge {
            display: inline-flex; align-items: center;
            background: rgba(124,58,237,.12); border: 1px solid rgba(124,58,237,.22);
            color: var(--primary-light); font-size: 10.5px; font-weight: 700;
            padding: 2px 9px; border-radius: 100px; margin-bottom: 7px;
            width: fit-content;
        }
        .star-row { display: flex; gap: 2px; margin-bottom: 8px; color: var(--accent); }
        .product-info p { font-size: .8rem; color: var(--text-muted); line-height: 1.5; height: 36px; overflow: hidden; margin-bottom: 14px; }
        .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
        .price { font-size: 1.1rem; font-weight: 800; }
        .price small { font-size: .72rem; color: var(--text-muted); font-weight: 400; margin-left: 2px; }

        /* ADD TO CART BUTTON */
        .add-cart-btn {
            background: linear-gradient(135deg, var(--primary), #5b21b6);
            color: #fff; border: none;
            height: 36px; padding: 0 14px; border-radius: 10px;
            cursor: pointer; display: flex; align-items: center; gap: 6px;
            font-size: 12.5px; font-weight: 700; font-family: inherit;
            box-shadow: 0 4px 12px rgba(124,58,237,.35);
            transition: transform .2s, box-shadow .2s;
            -webkit-text-fill-color: #fff;
        }
        .add-cart-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(124,58,237,.5); }
        .add-cart-btn:active { transform: scale(.95); }

        /* ============ CART SIDEBAR ============ */
        .cart-overlay {
            position: fixed; inset: 0; z-index: 1000;
            background: rgba(0,0,0,.65); backdrop-filter: blur(4px);
            opacity: 0; pointer-events: none; transition: opacity .35s ease;
        }
        .cart-overlay.open { opacity: 1; pointer-events: all; }
        .cart-sidebar {
            position: fixed; top: 0; right: 0;
            width: min(400px, 100vw); height: 100vh; z-index: 1001;
            background: var(--bg-card2); border-left: 1px solid var(--border);
            display: flex; flex-direction: column;
            transform: translateX(100%); transition: transform .4s cubic-bezier(.22,1,.36,1);
        }
        .cart-sidebar.open { transform: translateX(0); }
        .cart-head {
            padding: 20px 20px 16px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .cart-head h2 { font-size: 1.1rem; font-weight: 800; display: flex; align-items: center; gap: 8px; }
        .cart-badge-count {
            background: linear-gradient(135deg, var(--primary), #ec4899);
            color: #fff; font-size: 11px; font-weight: 700;
            padding: 2px 9px; border-radius: 100px;
        }
        .close-btn {
            width: 34px; height: 34px; border-radius: 10px;
            background: var(--surface); border: 1px solid var(--border);
            color: var(--text-muted); cursor: pointer;
            display: flex; align-items: center; justify-content: center; transition: .2s;
        }
        .close-btn:hover { color: var(--danger); border-color: var(--danger); }
        .cart-body { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 10px; }
        .cart-body::-webkit-scrollbar { width: 4px; }
        .cart-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
        .cart-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 14px; color: var(--text-faint); }
        .cart-item {
            display: flex; align-items: center; gap: 12px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 14px; padding: 12px;
            animation: slideIn .3s ease;
        }
        @keyframes slideIn { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:translateX(0); } }
        .ci-img { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; flex-shrink: 0; background: var(--bg-card); }
        .ci-info { flex: 1; overflow: hidden; }
        .ci-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .ci-price { font-size: 12px; color: var(--primary-light); font-weight: 700; margin-top: 3px; }
        .ci-qty { display: flex; align-items: center; gap: 7px; }
        .qty-btn {
            width: 26px; height: 26px; border-radius: 7px;
            background: var(--bg-card); border: 1px solid var(--border);
            color: var(--text-main); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 15px; font-weight: 700; line-height: 1; transition: .2s;
        }
        .qty-btn:hover { background: var(--primary); border-color: var(--primary); }
        .qty-n { font-size: 13px; font-weight: 700; min-width: 18px; text-align: center; }
        .cart-foot { padding: 16px 20px; border-top: 1px solid var(--border); }
        .cart-total-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
        .cart-total-row span:first-child { color: var(--text-muted); font-size: .9rem; }
        .cart-total-amount { font-size: 1.4rem; font-weight: 900; }
        .checkout-btn {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, var(--primary), #5b21b6);
            color: #fff; border: none; border-radius: 14px;
            font-size: .95rem; font-weight: 700; font-family: inherit;
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
            box-shadow: 0 6px 20px rgba(124,58,237,.4); transition: .25s;
            -webkit-text-fill-color: #fff;
        }
        .checkout-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(124,58,237,.55); }

        /* ============ TOAST ============ */
        #toast-wrap { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); z-index: 2000; pointer-events: none; display: flex; flex-direction: column; gap: 10px; align-items: center; }
        .toast {
            background: var(--bg-card); border: 1px solid rgba(124,58,237,.4);
            color: var(--text-main); padding: 11px 20px; border-radius: 14px;
            font-size: 14px; font-weight: 600;
            display: flex; align-items: center; gap: 9px; white-space: nowrap;
            box-shadow: 0 8px 24px rgba(0,0,0,.5);
            animation: tIn .35s cubic-bezier(.22,1,.36,1) both;
        }
        .toast.out { animation: tOut .3s ease forwards; }
        @keyframes tIn { from { opacity:0; transform:translateY(16px) scale(.92); } to { opacity:1; transform:none; } }
        @keyframes tOut { to { opacity:0; transform:translateY(8px) scale(.9); } }

        /* ============ PROFILE MODAL ============ */
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.7); backdrop-filter: blur(6px); z-index: 1100; opacity: 0; pointer-events: none; transition: opacity .3s; display: flex; align-items: center; justify-content: center; }
        .modal-overlay.open { opacity: 1; pointer-events: all; }
        .modal-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; width: min(420px, 92vw); padding: 32px; box-shadow: 0 24px 64px rgba(0,0,0,.6); animation: modalPop .3s cubic-bezier(.22,1,.36,1); }
        @keyframes modalPop { from { opacity:0; transform:scale(.9); } to { opacity:1; transform:scale(1); } }
        .modal-avatar { width: 72px; height: 72px; border-radius: 20px; background: linear-gradient(135deg, var(--primary), #ec4899); display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 900; color: #fff; margin: 0 auto 18px; }
        .modal-name { text-align: center; font-size: 1.3rem; font-weight: 800; margin-bottom: 4px; }
        .modal-email { text-align: center; color: var(--text-muted); font-size: .875rem; margin-bottom: 24px; }
        .modal-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 24px; }
        .stat-box { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 14px; text-align: center; }
        .stat-num { font-size: 1.4rem; font-weight: 900; color: var(--primary-light); }
        .stat-label { font-size: 11px; color: var(--text-faint); margin-top: 3px; }
        .modal-close-btn { width: 100%; padding: 13px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; color: var(--text-muted); font-size: .9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: .2s; }
        .modal-close-btn:hover { background: var(--primary); border-color: var(--primary); color: #fff; }
    </style>
</head>
<body>

<!-- ===== NAV ===== -->
<nav>
    <div class="nav-logo" onclick="window.location.href='/'">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        ShopEasy
    </div>

    <div class="nav-actions">
        <!-- Cart -->
        <button class="nav-icon-btn" id="cart-nav-btn" onclick="openCart()" aria-label="Cart">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-count" id="cart-counter">0</span>
        </button>

        <!-- Profile -->
        <div class="profile-wrap">
            <button class="nav-icon-btn c0" id="profile-btn" onclick="handleProfileClick(event)" aria-label="Profile">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </button>

            <div class="profile-dropdown" id="profile-dropdown">
                <!-- User card: shown if logged in -->
                <% if (typeof user !== 'undefined' && user) { %>
                <div class="pd-user-card">
                    <div class="pd-avatar"><%= user.email.charAt(0).toUpperCase() %></div>
                    <div>
                        <div class="pd-user-name"><%= user.email.split('@')[0] %></div>
                        <div class="pd-user-email"><%= user.email %></div>
                    </div>
                </div>
                <a href="#" onclick="openMyProfile(event)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    My Profile
                </a>
                <div class="pd-divider"></div>
                <a href="/logout" class="dd-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </a>
                <% } else { %>
                <!-- Guest state -->
                <div class="pd-user-card">
                    <div class="pd-avatar">?</div>
                    <div class="pd-guest-text">Not logged in</div>
                </div>
                <a href="/login/customer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    Customer Login
                </a>
                <div class="pd-divider"></div>
                <a href="/register">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    Register
                </a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<!-- ===== HERO ===== -->
<section class="hero">
    <div class="hero-badge">
        ✨ Premium Collection 2026
    </div>
    <h1>Shop Without<br>Limits</h1>
    <p>Discover handpicked products curated just for you. Premium quality, unbeatable prices.</p>
    <div class="search-bar">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-faint)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="search-input" placeholder="Search products…" oninput="filterProducts()">
    </div>
</section>

<!-- ===== FILTER CHIPS ===== -->
<div class="filter-row" id="filter-row">
    <span class="chip active" onclick="filterChip(this, 'all')">All Products</span>
    <%
        var cats = [];
        products.forEach(function(p) {
            var c = p.category || 'Uncategorized';
            if (cats.indexOf(c) === -1) cats.push(c);
        });
        cats.sort();
    %>
    <% cats.forEach(function(cat) { %>
    <span class="chip" onclick="filterChip(this, '<%= cat %>')"><%= cat %></span>
    <% }); %>
</div>

<!-- ===== PRODUCTS GRID ===== -->
<div class="products-grid" id="products-grid">
    <% products.forEach(function(product, i) { %>
    <div class="product-card"
         data-name="<%= (product.name || '').toLowerCase() %>"
         data-category="<%= (product.category || 'Uncategorized').toLowerCase() %>">
        <% if (i % 5 === 0) { %><span class="product-badge">🔥 Hot</span><% } else if (i % 4 === 0) { %><span class="product-badge">✨ New</span><% } %>
        <div class="img-container">
            <img
                src="<%= product.image || '' %>"
                alt="<%= product.name %>"
                onerror="this.src='https://placehold.co/400x300/1a1a2e/7c3aed?text=<%= encodeURIComponent(product.name || 'Product') %>'"
                loading="lazy"
            >
        </div>
        <div class="product-info">
            <h3><%= product.name %></h3>
            <div class="card-cat-badge"><%= product.category || 'Uncategorized' %></div>
            <div class="star-row">★★★★<span style="opacity:.3">★</span></div>
            <p><%= product.description %></p>
            <div class="card-footer">
                <div class="price">₹<%= product.price %><small>/ item</small></div>
                <button
                    class="add-cart-btn"
                    data-name="<%= product.name %>"
                    data-price="<%= product.price %>"
                    data-img="<%= product.image || '' %>"
                    onclick="addToCart(this)"
                >
                    🛒 Add
                </button>
            </div>
        </div>
    </div>
    <% }); %>
</div>

<!-- no results -->
<p id="no-results" style="display:none;text-align:center;color:var(--text-faint);padding:40px 0;font-size:14px;">No products found in this category.</p>

<!-- ===== CART OVERLAY + SIDEBAR ===== -->
<div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>
<div class="cart-sidebar" id="cart-sidebar">
    <div class="cart-head">
        <h2>Your Cart <span class="cart-badge-count" id="cart-badge">0</span></h2>
        <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-body" id="cart-body">
        <div class="cart-empty" id="cart-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.25"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <p>Your cart is empty</p>
        </div>
    </div>
    <div class="cart-foot">
        <div class="cart-total-row">
            <span>Total</span>
            <span class="cart-total-amount" id="cart-total">₹0</span>
        </div>
        <button class="checkout-btn" onclick="checkout()">
            💳 Proceed to Checkout
        </button>
    </div>
</div>

<!-- ===== MY PROFILE MODAL ===== -->
<div class="modal-overlay" id="profile-modal" onclick="closeModal(event)">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-avatar" id="modal-avatar">?</div>
        <div class="modal-name" id="modal-name">Guest User</div>
        <div class="modal-email" id="modal-email">Not logged in</div>
        <div class="modal-stats">
            <div class="stat-box"><div class="stat-num" id="modal-cart-count">0</div><div class="stat-label">In Cart</div></div>
            <div class="stat-box"><div class="stat-num">⭐ 4.8</div><div class="stat-label">Rating</div></div>
            <div class="stat-box"><div class="stat-num">🎁 3</div><div class="stat-label">Orders</div></div>
        </div>
        <button class="modal-close-btn" onclick="document.getElementById('profile-modal').classList.remove('open')">Close</button>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div id="toast-wrap"></div>

<!-- ===== SCRIPTS ===== -->
<script>
    /* ---- CART STATE ---- */
    var cart = []; // [{name, price, img, qty}]

    function cartTotal() {
        return cart.reduce(function(s, i) { return s + i.price * i.qty; }, 0);
    }
    function cartItemCount() {
        return cart.reduce(function(s, i) { return s + i.qty; }, 0);
    }

    /* ---- ADD TO CART ---- */
    function addToCart(btn) {
        var name  = btn.getAttribute('data-name');
        var price = parseFloat(btn.getAttribute('data-price')) || 0;
        var img   = btn.getAttribute('data-img') || '';

        var idx = cart.findIndex(function(i) { return i.name === name; });
        if (idx >= 0) {
            cart[idx].qty++;
        } else {
            cart.push({ name: name, price: price, img: img, qty: 1 });
        }

        renderCart();
        bumpBadge();
        showToast('🛒 ' + name + ' added!');

        // Button press animation
        btn.style.transform = 'scale(0.9)';
        setTimeout(function() { btn.style.transform = ''; }, 180);
    }

    function changeQty(idx, d) {
        cart[idx].qty += d;
        if (cart[idx].qty <= 0) cart.splice(idx, 1);
        renderCart();
    }

    /* ---- RENDER CART ---- */
    function renderCart() {
        var body   = document.getElementById('cart-body');
        var empty  = document.getElementById('cart-empty');
        var total  = document.getElementById('cart-total');
        var badge  = document.getElementById('cart-badge');
        var navBadge = document.getElementById('cart-counter');

        // Remove old cart items (not the empty state div)
        var existing = body.querySelectorAll('.cart-item');
        existing.forEach(function(el) { el.remove(); });

        var count = cartItemCount();
        navBadge.innerText = count;
        badge.innerText = count;

        if (cart.length === 0) {
            empty.style.display = 'flex';
            total.innerText = '₹0';
        } else {
            empty.style.display = 'none';
            cart.forEach(function(item, i) {
                var div = document.createElement('div');
                div.className = 'cart-item';
                div.innerHTML =
                    '<img class="ci-img" src="' + (item.img || 'https://placehold.co/50x50/1a1a2e/7c3aed?text=P') + '" ' +
                    'onerror="this.src=\'https://placehold.co/50x50/1a1a2e/7c3aed?text=P\'" alt="' + item.name + '">' +
                    '<div class="ci-info">' +
                        '<div class="ci-name">' + item.name + '</div>' +
                        '<div class="ci-price">₹' + item.price + '</div>' +
                    '</div>' +
                    '<div class="ci-qty">' +
                        '<button class="qty-btn" onclick="changeQty(' + i + ',-1)">−</button>' +
                        '<span class="qty-n">' + item.qty + '</span>' +
                        '<button class="qty-btn" onclick="changeQty(' + i + ',1)">+</button>' +
                    '</div>';
                body.appendChild(div);
            });
            total.innerText = '₹' + cartTotal().toLocaleString('en-IN');
        }

        // Update profile modal cart count
        document.getElementById('modal-cart-count').innerText = count;
    }

    function bumpBadge() {
        var b = document.getElementById('cart-counter');
        b.classList.remove('bump');
        void b.offsetWidth;
        b.classList.add('bump');
        setTimeout(function() { b.classList.remove('bump'); }, 350);
    }

    /* ---- CART OPEN / CLOSE ---- */
    function openCart() {
        document.getElementById('cart-overlay').classList.add('open');
        document.getElementById('cart-sidebar').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeCart() {
        document.getElementById('cart-overlay').classList.remove('open');
        document.getElementById('cart-sidebar').classList.remove('open');
        document.body.style.overflow = '';
    }
    function checkout() {
        if (cart.length === 0) { showToast('⚠️ Add items to cart first!'); return; }
        showToast('✅ Order placed! Thank you 🎉');
        cart = [];
        renderCart();
        closeCart();
    }

    /* ---- PROFILE DROPDOWN (CLICK-TOGGLE) ---- */
    var profileColorIdx = 0;
    var profileColors   = ['c0','c1','c2','c3','c4','c5'];
    var colorNames      = ['Indigo','Sky Blue','Emerald','Amber','Red','Pink'];

    function handleProfileClick(e) {
        e.stopPropagation();
        var dd  = document.getElementById('profile-dropdown');
        var btn = document.getElementById('profile-btn');

        if (dd.classList.contains('open')) {
            dd.classList.remove('open');
        } else {
            // Cycle color
            btn.classList.remove(profileColors[profileColorIdx]);
            profileColorIdx = (profileColorIdx + 1) % profileColors.length;
            btn.classList.add(profileColors[profileColorIdx]);
            dd.classList.add('open');
            showToast('🎨 ' + colorNames[profileColorIdx]);
        }
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        var dd = document.getElementById('profile-dropdown');
        var wrap = document.querySelector('.profile-wrap');
        if (dd.classList.contains('open') && !wrap.contains(e.target)) {
            dd.classList.remove('open');
        }
    });

    /* ---- MY PROFILE MODAL ---- */
    <% if (typeof user !== 'undefined' && user) { %>
    var _userEmail = '<%= user.email %>';
    var _userName  = '<%= user.email.split("@")[0] %>';
    <% } else { %>
    var _userEmail = null;
    var _userName  = null;
    <% } %>

    function openMyProfile(e) {
        e.preventDefault();
        document.getElementById('profile-dropdown').classList.remove('open');

        if (_userName) {
            document.getElementById('modal-avatar').innerText = _userEmail.charAt(0).toUpperCase();
            document.getElementById('modal-name').innerText   = _userName;
            document.getElementById('modal-email').innerText  = _userEmail;
        } else {
            document.getElementById('modal-avatar').innerText = '?';
            document.getElementById('modal-name').innerText   = 'Guest User';
            document.getElementById('modal-email').innerText  = 'Please login to see your profile';
        }
        document.getElementById('modal-cart-count').innerText = cartItemCount();
        document.getElementById('profile-modal').classList.add('open');
    }

    function closeModal(e) {
        if (e.target === document.getElementById('profile-modal')) {
            document.getElementById('profile-modal').classList.remove('open');
        }
    }

    /* ---- SEARCH ---- */
    function filterProducts() {
        applyFilters();
    }

    /* ---- CHIP FILTER (real category filtering) ---- */
    var activeCategory = 'all';

    function filterChip(el, cat) {
        document.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('active'); });
        el.classList.add('active');
        activeCategory = (cat || 'all').toLowerCase();
        applyFilters();
    }

    function applyFilters() {
        var q   = (document.getElementById('search-input').value || '').toLowerCase();
        var cat = activeCategory;
        var visible = 0;
        document.querySelectorAll('.product-card').forEach(function(card) {
            var nameMatch = (card.dataset.name || '').includes(q);
            var catMatch  = (cat === 'all') || (card.dataset.category || '') === cat;
            var show = nameMatch && catMatch;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        var noRes = document.getElementById('no-results');
        if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
    }

    /* ---- SCROLL REVEAL ---- */
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) {
                e.target.style.opacity = '1';
                e.target.style.transform = 'translateY(0)';
                observer.unobserve(e.target);
            }
        });
    }, { threshold: 0.08 });

    document.querySelectorAll('.product-card').forEach(function(card, i) {
        card.style.transitionDelay = (i * 0.04) + 's';
        observer.observe(card);
    });

    /* ---- TOAST ---- */
    function showToast(msg) {
        var wrap  = document.getElementById('toast-wrap');
        var toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ' + msg;
        wrap.appendChild(toast);
        setTimeout(function() {
            toast.classList.add('out');
            setTimeout(function() { toast.remove(); }, 320);
        }, 2600);
    }
</script>
</body>
</html>